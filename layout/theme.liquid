<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#1c1a1a">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if request.page_type == 'index' %}
      <meta name="description" content="Laura Milman — fine jewelry crafted in New York. Heirloom engagement rings, diamond pendants, bracelets, earrings and necklaces from the Milman family workshop. Complimentary shipping, 30-day returns and lifetime warranty.">
    {% elsif page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"></noscript>

    {{ 'laura-milman.css' | asset_url | stylesheet_tag }}
    {% render 'lm-palette-overrides' %}

    {{ content_for_header }}

    {%- liquid
      assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}

    {% style %}
      :root {
        --primary-dark: {{ settings.primary_color | default: '#1c1a1a' }};
        --primary-dark-light: {{ settings.primary_color | color_lighten: 10 | default: '#322f2f' }};
        --primary-dark-darker: {{ settings.primary_color | color_darken: 10 | default: '#0d0c0c' }};
        --accent-gold: {{ settings.accent_color | default: '#dea882' }};
        --accent-gold-light: {{ settings.accent_color | color_lighten: 10 | default: '#e8bf9e' }};
        --accent-gold-dark: {{ settings.accent_color | color_darken: 10 | default: '#c89066' }};
        --accent-forest: #476154;
        --accent-deep-red: #850000;
        --accent-beige: #c1bcae;
        --bg-cream: #efecec;
        --bg-cream-soft: #f5f5f5;
        --bg-white: #ffffff;
        --text-dark: #1c1a1a;
        --text-muted: #7b8382;
        --border-light: #e5e2dc;
      }
    {% endstyle %}

    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>

    {%- comment -%} TODO: Add LM customer-service phone + email to contactPoint below once confirmed. {%- endcomment -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Laura Milman",
      "alternateName": "Laura Milman New York",
      "url": "{{ shop.url }}",
      "logo": "{{ 'logo.svg' | asset_url | prepend: 'https:' }}",
      "description": "Laura Milman is a New York heritage fine jewelry brand from the Milman family workshop, offering heirloom engagement rings, diamond pendants, bracelets, earrings and necklaces.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "New York",
        "addressRegion": "NY",
        "addressCountry": "US"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service"
      },
      "sameAs": [
        "https://instagram.com/laurasgemsnyc",
        "https://facebook.com/laurasgemsnyc",
        "https://tiktok.com/@laurasgemsnyc"
      ]
    }
    </script>
  </head>

  <body class="template-{{ template.name }}">
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}'
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`
      }

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
      }
    </script>

    {{ 'laura-milman.js' | asset_url | script_tag }}
  </body>
</html>
