<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.accent_color }}">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <style>
    :root {
      --accent: {{ settings.accent_color }};
      --bg-deep: {{ settings.bg_color }};
      --bg-mid: #2A1A10;
      --bg-warm: #3D2518;
      --text-primary: #EBE1D2;
    }
  </style>

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- section 'header' -%}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  {%- render 'chat-widget' -%}

  <div id="cart-notification" class="cart-notification" aria-live="polite" aria-atomic="true" hidden>
    <p class="cart-notification__text">Added to cart</p>
  </div>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
