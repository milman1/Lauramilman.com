{%- comment -%}
  Laura Milman — Featured Collection section.
  Reuses snippets/product-card. Palette + voice swapped.
{%- endcomment -%}

<section class="products-section section">
  <div class="container">
    <div class="products__header">
      <div>
        <h2>{{ section.settings.heading | default: 'Pieces of note' }}</h2>
        <p class="text-muted">{{ section.settings.subheading | default: 'Recent work from the atelier' }}</p>
      </div>
      {%- if section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}" class="btn btn--outline">View all</a>
      {%- endif -%}
    </div>

    <div class="products-grid">
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <article class="product-card">
            <div class="product-card__image-wrapper">
              <div class="product-card__image" style="background: linear-gradient(135deg, #efecec 0%, #c1bcae 100%); display: flex; align-items: center; justify-content: center;">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </div>
            <div class="product-card__content">
              <h4 class="product-card__title">Sample piece {{ i }}</h4>
              <p class="product-card__price">$999</p>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pieces of note" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Recent work from the atelier" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 4, "label": "Products to show" }
  ],
  "presets": [ { "name": "Featured Collection" } ]
}
{% endschema %}
