<style>
  .estate-designers {
    background: var(--warm-white, #FBF9F6);
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }
  .estate-designers[style*="--estate-bg-img"] {
    background-size: cover;
    background-position: center;
    background-image: var(--estate-bg-img);
  }
  .estate-designers__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }
  .estate-designers .eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold, #C1A784);
    margin-bottom: 16px;
  }
  .estate-designers .section-title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 400;
    color: var(--espresso, #2C1810);
    margin: 0 0 20px;
    line-height: 1.2;
  }
  .estate-designers__desc {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-muted, #6B5E54);
    max-width: 560px;
    margin: 0 auto 48px;
  }
  .estate-designers__selector-wrap {
    max-width: 480px;
    margin: 0 auto 40px;
  }
  .estate-designers__label {
    display: block;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dark, #2C1810);
    margin-bottom: 12px;
  }
  .estate-designers__select-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
  }
  .estate-designers__select-box {
    flex: 1;
    position: relative;
  }
  .estate-designers__select {
    width: 100%;
    height: 52px;
    padding: 0 40px 0 18px;
    border: 1px solid var(--gold-pale, #E8DFD3);
    border-radius: 4px;
    background: #fff;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 14px;
    color: var(--text-dark, #2C1810);
    appearance: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .estate-designers__select:focus {
    outline: none;
    border-color: var(--gold, #C1A784);
  }
  .estate-designers__chevron {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--gold, #C1A784);
  }
  .estate-designers__browse-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 24px;
    background: var(--gold, #C1A784);
    color: #fff;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    white-space: nowrap;
    transition: background 0.25s, opacity 0.25s;
    opacity: 0.5;
    pointer-events: none;
  }
  .estate-designers__browse-btn--active {
    opacity: 1;
    pointer-events: auto;
  }
  .estate-designers__browse-btn--active:hover {
    background: var(--espresso, #2C1810);
  }
  .estate-designers__footer {
    border-top: 1px solid var(--rule-light, #E8E2DA);
    padding-top: 24px;
    margin-top: 8px;
  }
  .estate-designers__partner-note {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    font-style: italic;
    color: var(--text-muted, #6B5E54);
    margin: 0;
  }

  @media (max-width: 600px) {
    .estate-designers { padding: 56px 0; }
    .estate-designers__select-row {
      flex-direction: column;
    }
    .estate-designers__browse-btn {
      justify-content: center;
      height: 48px;
    }
  }
</style>

<section class="estate-designers" id="estate-designers"
  {%- if section.settings.bg_image != blank -%}
  style="--estate-bg-img: url('{{ section.settings.bg_image | image_url: width: 1800 }}')"
  {%- endif -%}
>
  <div class="estate-designers__inner">

    <div class="estate-designers__header">
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="estate-designers__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="estate-designers__selector-wrap">
      <label class="estate-designers__label" for="designer-select-{{ section.id }}">
        Browse by Designer
      </label>

      <div class="estate-designers__select-row">
        <div class="estate-designers__select-box">
          <select
            id="designer-select-{{ section.id }}"
            class="estate-designers__select"
            onchange="estateDesignerNav(this)"
          >
            <option value="">— Select a Designer —</option>

            <optgroup label="A – B">
              <option value="/collections/adler">Adler</option>
              <option value="/collections/boucheron">Boucheron</option>
              <option value="/collections/buccellati">Buccellati</option>
              <option value="/collections/bvlgari">Bulgari</option>
            </optgroup>

            <optgroup label="C">
              <option value="/collections/cartier">Cartier</option>
              <option value="/collections/chopard">Chopard</option>
            </optgroup>

            <optgroup label="D – F">
              <option value="/collections/david-webb">David Webb</option>
              <option value="/collections/fred">Fred</option>
            </optgroup>

            <optgroup label="G – M">
              <option value="/collections/graff">Graff</option>
              <option value="/collections/harry-winston">Harry Winston</option>
              <option value="/collections/hermes">Hermès</option>
              <option value="/collections/marina-b">Marina B.</option>
            </optgroup>

            <optgroup label="P – V">
              <option value="/collections/piaget">Piaget</option>
              <option value="/collections/roberto-coin">Roberto Coin</option>
              <option value="/collections/seaman-schepps">Seaman Schepps</option>
              <option value="/collections/tiffany-co">Tiffany &amp; Co.</option>
              <option value="/collections/van-cleef-arpels">Van Cleef &amp; Arpels</option>
              <option value="/collections/verdura">Verdura</option>
            </optgroup>
          </select>
          <span class="estate-designers__chevron" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 6l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>

        <a
          id="estate-designer-cta-{{ section.id }}"
          class="estate-designers__browse-btn"
          href="#"
          aria-disabled="true"
          tabindex="-1"
        >
          <span class="estate-designers__browse-label">Browse this Designer</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    {%- if section.settings.partner_note != blank -%}
      <div class="estate-designers__footer">
        <p class="estate-designers__partner-note">{{ section.settings.partner_note }}</p>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  function estateDesignerNav(select) {
    var path  = select.value;
    var name  = select.options[select.selectedIndex].text;
    var sectionEl = select.closest('.estate-designers');
    var cta   = sectionEl.querySelector('.estate-designers__browse-btn');
    var label = cta.querySelector('.estate-designers__browse-label');

    if (path) {
      cta.href = path;
      cta.removeAttribute('aria-disabled');
      cta.removeAttribute('tabindex');
      cta.classList.add('estate-designers__browse-btn--active');
      label.textContent = 'Browse ' + name;
    } else {
      cta.href = '#';
      cta.setAttribute('aria-disabled', 'true');
      cta.setAttribute('tabindex', '-1');
      cta.classList.remove('estate-designers__browse-btn--active');
      label.textContent = 'Browse this Designer';
    }
  }
</script>

{% schema %}
{
  "name": "Estate Designers",
  "tag": "section",
  "class": "section-estate-designers",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Pre-Owned · Antique · Estate"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Antique & Estate Jewelry"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Individually authenticated pieces from the world's most prestigious jewelry houses. Each carries its own history and has been carefully restored to its original splendor."
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image (optional)"
    },
    {
      "type": "textarea",
      "id": "partner_note",
      "label": "Note (optional)",
      "default": "All estate pieces are pre-owned and individually authenticated."
    }
  ],
  "presets": [
    {
      "name": "Estate Designers"
    }
  ]
}
{% endschema %}
