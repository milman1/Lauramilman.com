.rsg-table tbody tr:last-child td { border-bottom: none; }
.rsg-table tbody tr:hover { background: rgba(222,168,130,.05); }
.rsg-table tbody td:first-child { color: #fff; font-weight: 600; }

.rsg-tips { background: rgba(222,168,130,.06); border: 1px solid rgba(222,168,130,.2); border-radius: 4px; padding: 1.75rem 2rem; margin-top: 1.5rem; }
.rsg-tips__title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.3rem; font-weight: 400; color: var(--accent-gold, #dea882); margin: 0 0 1rem; font-style: italic; }
