.rsg-steps li::before { content: counter(rsg-step); position: absolute; left: 0; top: 0; width: 1.75rem; height: 1.75rem; border-radius: 50%; border: 1px solid var(--accent-gold, #dea882); color: var(--accent-gold, #dea882); font-size: 0.85rem; font-weight: 600; display: flex; align-items: center; justify-content: center; line-height: 1; }

.rsg-bullets { list-style: none; padding: 0; margin: 1.25rem 0 0; }
