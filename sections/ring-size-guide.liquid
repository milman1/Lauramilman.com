.rsg-hero__title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 400; line-height: 1.2; margin: 0 0 1.25rem; color: #fff; font-style: italic; }
