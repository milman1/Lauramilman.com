.rsg-faq { margin-top: 1.5rem; }
.rsg-faq__item { border-bottom: 1px solid rgba(255,255,255,.06); }
.rsg-faq__item:last-child { border-bottom: none; }
.rsg-faq__q { width: 100%; background: none; border: none; text-align: left; padding: 1.25rem 2.5rem 1.25rem 0; font-size: 1.05rem; font-weight: 500; color: #fff; cursor: pointer; position: relative; font-family: inherit; line-height: 1.5; transition: color .2s; }
.rsg-faq__q:hover { color: var(--accent-gold, #dea882); }
.rsg-faq__q::after { content: '+'; position: absolute; right: 0; top: 50%; transform: translateY(-50%); font-size: 1.4rem; color: var(--accent-gold, #dea882); transition: transform .25s; font-weight: 300; }
.rsg-faq__item.is-open .rsg-faq__q::after { content: '−'; }
.rsg-faq__a { max-height: 0; overflow: hidden; transition: max-height .35s ease, padding .35s ease; padding: 0 0 0; }
.rsg-faq__item.is-open .rsg-faq__a { max-height: 200px; padding-bottom: 1.25rem; }
.rsg-faq__a p { margin: 0; font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,.68); }

.rsg-cta { text-align: center; margin-top: 3.5rem; padding-top: 2.5rem; border-top: 1px solid rgba(255,255,255,.06); }
.rsg-cta__text { font-size: 1.05rem; color: rgba(255,255,255,.68); margin: 0 0 0.5rem; line-height: 1.7; }
.rsg-cta__text a { color: var(--accent-gold, #dea882); text-decoration: underline; text-underline-offset: 3px; }
.rsg-cta__text a:hover { color: #fff; }
.rsg-cta__link { display: inline-block; margin-top: 1.5rem; padding: 0.85rem 2.25rem; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: #1c1a1a; background: var(--accent-gold, #dea882); border-radius: 2px; text-decoration: none; transition: background .25s, transform .25s; }
