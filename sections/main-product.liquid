{%- comment -%}
  Laura Milman New York — Product Detail Page
  Two-column: image gallery (left) + sticky product info (right)
  Metafield display, variant selector, accordion details, trust badges
{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}

<div class="product-page">

  <!-- Breadcrumb -->
  <nav class="product-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="sep" aria-hidden="true">/</span>
    {%- if collection -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span class="sep" aria-hidden="true">/</span>
    {%- endif -%}
    <span class="current" aria-current="page">{{ product.title }}</span>
  </nav>

  <!-- Product Layout -->
  <div class="product-layout">

    <!-- Gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main">
        {%- if product.tags contains 'new' or product.tags contains 'new-arrival' -%}
          <div class="product-gallery__badge">New Arrival</div>
        {%- endif -%}

        {%- if product.featured_image -%}
          <img
            id="product-main-image"
            src="{{ product.featured_image | image_url: width: 1200 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            loading="eager"
          >
        {%- endif -%}

        <div class="product-gallery__zoom-hint" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(193,167,132,0.4)" stroke-width="1.5">
            <circle cx="11" cy="11" r="7"/>
            <path d="m21 21-4.35-4.35"/>
            <path d="M11 8v6M8 11h6"/>
          </svg>
          Hover to zoom
        </div>
      </div>

      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs" role="list">
          {%- for image in product.images limit: 6 -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} active{% endif %}"
              data-src="{{ image | image_url: width: 1200 }}"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                width="120"
                height="120"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product Info -->
    <div class="product-info">

      {%- if product.vendor != blank -%}
        <p class="product-vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 class="product-title">{{ product.title }}</h1>

      <!-- Price -->
      <div class="product-price-row">
        <span class="product-price" id="product-price-display">
          {{ current_variant.price | money }}
        </span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <s class="product-price--compare" id="product-compare-price">{{ current_variant.compare_at_price | money }}</s>
          <span class="product-price--save">
            Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
          </span>
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div class="product-description">{{ product.description | strip_html | truncate: 300 }}</div>
      {%- endif -%}

      <!-- Metafield Specs -->
      {%- assign has_meta = false -%}
      {%- if product.metafields.custom.carat_weight != blank or product.metafields.custom.color != blank or product.metafields.custom.clarity != blank or product.metafields.custom.metal != blank -%}
        {%- assign has_meta = true -%}
      {%- endif -%}

      {%- if has_meta -%}
        <div class="product-specs">
          {%- if product.metafields.custom.carat_weight != blank -%}
            <div class="product-spec">
              <span class="product-spec__label">Carat</span>
              <span class="product-spec__value">{{ product.metafields.custom.carat_weight }}</span>
            </div>
          {%- endif -%}
          {%- if product.metafields.custom.color != blank -%}
            <div class="product-spec">
              <span class="product-spec__label">Color</span>
              <span class="product-spec__value">{{ product.metafields.custom.color }}</span>
            </div>
          {%- endif -%}
          {%- if product.metafields.custom.clarity != blank -%}
            <div class="product-spec">
              <span class="product-spec__label">Clarity</span>
              <span class="product-spec__value">{{ product.metafields.custom.clarity }}</span>
            </div>
          {%- endif -%}
          {%- if product.metafields.custom.metal != blank -%}
            <div class="product-spec">
              <span class="product-spec__label">Metal</span>
              <span class="product-spec__value">{{ product.metafields.custom.metal }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="gold-divider"></div>

      <!-- Product Form -->
      {%- form 'product', product, id: product_form_id, data-product-form: '' -%}

        <select name="id" style="display:none;" aria-label="Variant">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              data-options="{{ variant.options | json | escape }}"
              data-available="{{ variant.available }}"
              data-price="{{ variant.price }}"
              data-compare-price="{{ variant.compare_at_price }}"
              {% if variant == current_variant %}selected{% endif %}
            >
              {{ variant.title }}
            </option>
          {%- endfor -%}
        </select>

        <!-- Options -->
        {%- for option in product.options_with_values -%}
          <div class="product-option-label" style="margin-top:{{ forloop.first | if: '0', '28px' }}">
            {{ option.name }} — <span>{{ current_variant.options[forloop.index0] }}</span>
          </div>

          <div class="product-option-row" data-option-group data-option-index="{{ forloop.index0 }}">
            {%- for value in option.values -%}
              {%- assign is_active = false -%}
              {%- if current_variant.options[forloop.parentloop.index0] == value -%}
                {%- assign is_active = true -%}
              {%- endif -%}

              <button
                type="button"
                class="product-option-btn{% if option.name == 'Size' %} size-btn{% endif %}{% if is_active %} active{% endif %}"
                data-value="{{ value | escape }}"
                aria-pressed="{{ is_active }}"
              >
                {{ value }}
              </button>
            {%- endfor -%}
          </div>
        {%- endfor -%}

        <!-- Quantity + Add to Cart -->
        <div class="atc-row">
          <div class="quantity-selector">
            <button type="button" class="qty-btn" data-action="minus" aria-label="Decrease quantity">−</button>
            <div class="qty-display" aria-live="polite">1</div>
            <button type="button" class="qty-btn" data-action="plus" aria-label="Increase quantity">+</button>
          </div>
          <input type="hidden" name="quantity" value="1">

          <button
            type="submit"
            class="atc-btn"
            {% unless current_variant.available %}disabled{% endunless %}
            aria-label="Add {{ product.title }} to cart"
          >
            {%- if current_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>

          <button type="button" class="wishlist-btn" aria-label="Add to wishlist">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C1A784" stroke-width="1.5" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
          </button>
        </div>

      {%- endform -%}

      <!-- Trust Badges -->
      <div class="trust-badges">
        <div class="trust-badge">
          <span class="trust-badge__icon" aria-hidden="true">◇</span>
          <span class="trust-badge__label">Authenticity Guaranteed</span>
        </div>
        <div class="trust-badge">
          <span class="trust-badge__icon" aria-hidden="true">⟡</span>
          <span class="trust-badge__label">Free Insured Shipping</span>
        </div>
        <div class="trust-badge">
          <span class="trust-badge__icon" aria-hidden="true">↻</span>
          <span class="trust-badge__label">30-Day Returns</span>
        </div>
      </div>

      <!-- Accordion: Materials -->
      <div class="accordion-item" data-open>
        <button class="accordion-trigger" aria-expanded="true" aria-controls="acc-materials-{{ section.id }}">
          Materials &amp; Craftsmanship
          <span class="accordion-icon" aria-hidden="true">+</span>
        </button>
        <div class="accordion-body" id="acc-materials-{{ section.id }}">
          <div class="accordion-content">
            {%- if product.metafields.custom.materials != blank -%}
              {{ product.metafields.custom.materials }}
            {%- else -%}
              {{ product.description }}
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Accordion: Shipping -->
      <div class="accordion-item">
        <button class="accordion-trigger" aria-expanded="false" aria-controls="acc-shipping-{{ section.id }}">
          Shipping &amp; Returns
          <span class="accordion-icon" aria-hidden="true">+</span>
        </button>
        <div class="accordion-body" id="acc-shipping-{{ section.id }}">
          <div class="accordion-content">
            {%- if section.settings.shipping_text != blank -%}
              {{ section.settings.shipping_text }}
            {%- else -%}
              All pieces ship via insured FedEx with signature required. Free shipping on all orders. 30-day returns accepted for unworn items in original packaging.
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Accordion: Care -->
      <div class="accordion-item">
        <button class="accordion-trigger" aria-expanded="false" aria-controls="acc-care-{{ section.id }}">
          Care Guide
          <span class="accordion-icon" aria-hidden="true">+</span>
        </button>
        <div class="accordion-body" id="acc-care-{{ section.id }}">
          <div class="accordion-content">
            {%- if section.settings.care_text != blank -%}
              {{ section.settings.care_text }}
            {%- else -%}
              Store in provided jewelry box. Clean with soft cloth. Avoid contact with chemicals, perfumes, and chlorine.
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Share -->
      <div class="product-share">
        <span class="product-share__label">Share</span>
        <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_image | image_url: width: 1200 }}&description={{ product.title | url_encode }}"
          target="_blank" rel="noopener" class="product-share__link">Pinterest</a>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}"
          target="_blank" rel="noopener" class="product-share__link">Facebook</a>
      </div>

    </div><!-- /product-info -->
  </div><!-- /product-layout -->

  <!-- Promise Banner -->
  <div class="promise-banner">
    <div class="eyebrow">The {{ shop.name }} Promise</div>
    <h2 class="promise-banner__title">Crafted to Last a Lifetime</h2>
    <p class="promise-banner__body">Every piece is handcrafted using ethically sourced materials and time-honored techniques passed down through generations of New York's finest jewelers.</p>
    <div class="promise-stats">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div {{ block.shopify_attributes }}>
            <div class="promise-stat__num">{{ block.settings.number }}</div>
            <div class="promise-stat__label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Related Products -->
  {%- assign related = product.metafields.custom.related_products.value | default: collections[product.collections.first.handle].products -%}
  {%- if related.size > 1 -%}
    <div class="related-products">
      <div class="related-products__divider"></div>
      <div class="related-products__header">
        <div class="eyebrow">You May Also Love</div>
        <h2 class="related-products__title">Complete the Look</h2>
      </div>
      <div class="products-grid">
        {%- for related_product in related limit: 4 -%}
          {%- unless related_product.handle == product.handle -%}
            {%- render 'product-card', product: related_product -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div><!-- /product-page -->

<!-- Metafield specs inline styles -->
<style>
  .product-vendor {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold, #C1A784);
    margin: 0 0 0.5rem;
  }

  .product-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    margin: 1.5rem 0;
    border: 1px solid var(--rule-light, rgba(193, 167, 132, 0.15));
  }

  .product-spec {
    padding: 12px 16px;
    border-bottom: 1px solid var(--rule-light, rgba(193, 167, 132, 0.15));
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .product-spec:nth-child(odd) {
    border-right: 1px solid var(--rule-light, rgba(193, 167, 132, 0.15));
  }

  .product-spec:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .product-spec__label {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted, #8B7D6B);
  }

  .product-spec__value {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--text-dark, #2C1810);
  }
</style>

<!-- Product JSON-LD -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 200 | json }},
  "image": [
    {%- for image in product.images limit: 5 -%}
      {{ image.src | image_url: width: 1024 | prepend: "https:" | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "url": "{{ shop.url }}{{ product.url }}",
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }}
  },
  "sku": {{ current_variant.sku | json }},
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "price": "{{ product.price | money_without_currency | remove: ',' }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    }
  }
  {%- if product.metafields.custom.metal != blank -%}
  ,"material": {{ product.metafields.custom.metal | json }}
  {%- endif -%}
}
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "textarea",
      "id": "shipping_text",
      "label": "Shipping & Returns text",
      "default": "All pieces ship via insured FedEx with signature required. Free shipping on all orders. 30-day returns accepted for unworn items."
    },
    {
      "type": "textarea",
      "id": "care_text",
      "label": "Care Guide text",
      "default": "Store in provided jewelry box. Clean with soft cloth. Avoid contact with chemicals."
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (symbol or emoji)",
          "default": "◇"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Authenticity Guaranteed"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Promise Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number / figure",
          "default": "18k"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Solid Gold"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product",
      "blocks": [
        {
          "type": "trust_badge",
          "settings": { "icon": "◇", "label": "Authenticity Guaranteed" }
        },
        {
          "type": "trust_badge",
          "settings": { "icon": "⟡", "label": "Free Insured Shipping" }
        },
        {
          "type": "trust_badge",
          "settings": { "icon": "↻", "label": "30-Day Returns" }
        },
        {
          "type": "stat",
          "settings": { "number": "18k", "label": "Solid Gold" }
        },
        {
          "type": "stat",
          "settings": { "number": "30", "label": "Day Returns" }
        }
      ]
    }
  ]
}
{% endschema %}
