{%- comment -%}
  Laura Milman — Header Section.
  Solid heritage-dark header with backdrop blur on scroll. Layout and
  interactions cloned from PD theme; brand voice rewritten and palette
  swapped to LM tokens.
{%- endcomment -%}

<style>
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  padding: 1rem 0; transition: all 0.3s ease;
  background: rgba(28, 26, 26, 0.97);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
}
.header--scrolled {
  background: rgba(28, 26, 26, 0.98);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
  padding: 0.75rem 0;
}
.header .container { max-width: 1400px; margin: 0 auto; padding: 0 2rem; }
.header__inner { display: flex; align-items: center; justify-content: space-between; }

/* Logo */
.header .logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.65rem; font-weight: 500;
  color: #ffffff; text-decoration: none;
  letter-spacing: 0.06em;
  transition: opacity 0.3s ease;
}
.header .logo:hover { opacity: 0.85; }
.header .logo span { color: var(--accent-gold, #dea882); font-style: italic; }
.header .logo img { height: 64px; width: auto; object-fit: contain; }

/* Navigation */
.header .nav { display: flex; align-items: center; gap: 2.5rem; }
.header .nav__link {
  font-size: 0.78rem; font-weight: 500;
  color: rgba(255, 255, 255, 0.92);
  text-decoration: none;
  text-transform: uppercase; letter-spacing: 0.22em;
  padding: 0.5rem 0; position: relative;
  transition: color 0.3s ease;
}
.header .nav__link::after {
  content: ''; position: absolute; bottom: 0; left: 0;
  width: 0; height: 1px;
  background: var(--accent-gold, #dea882);
  transition: width 0.3s ease;
}
.header .nav__link:hover { color: var(--accent-gold, #dea882); }
.header .nav__link:hover::after,
.header .nav__link--active::after { width: 100%; }
.header .nav__link--active { color: var(--accent-gold, #dea882); }

/* Icons */
.header .nav__icons { display: flex; align-items: center; gap: 1.25rem; }
.header .nav__icon {
  color: rgba(255, 255, 255, 0.92);
  transition: color 0.3s ease, transform 0.3s ease;
  display: flex; align-items: center; justify-content: center;
}
.header .nav__icon:hover { color: var(--accent-gold, #dea882); transform: translateY(-2px); }
.header .nav__icon svg { width: 22px; height: 22px; }
.header .cart-icon { position: relative; }
.header .cart-count {
  position: absolute; top: -8px; right: -10px;
  background: var(--accent-gold, #dea882); color: #1c1a1a;
  font-size: 0.65rem; font-weight: 600;
  width: 18px; height: 18px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}

/* Dropdown Menu */
.header .nav__item { position: relative; }
.header .nav__item-link {
  font-size: 0.78rem; font-weight: 500;
  color: rgba(255, 255, 255, 0.92);
  text-decoration: none;
  text-transform: uppercase; letter-spacing: 0.22em;
  padding: 0.5rem 0; position: relative;
  transition: color 0.3s ease;
  display: flex; align-items: center; gap: 0.35rem; cursor: pointer;
}
.header .nav__item-link::after {
  content: ''; position: absolute; bottom: 0; left: 0;
  width: 0; height: 1px;
  background: var(--accent-gold, #dea882);
  transition: width 0.3s ease;
}
.header .nav__item:hover .nav__item-link,
.header .nav__item-link:hover { color: var(--accent-gold, #dea882); }
.header .nav__item:hover .nav__item-link::after,
.header .nav__item-link:hover::after { width: 100%; }
.header .nav__item-link .dropdown-arrow { width: 10px; height: 10px; transition: transform 0.3s ease; }
.header .nav__item:hover .dropdown-arrow { transform: rotate(180deg); }

.header .nav__dropdown {
  position: absolute; top: 100%; left: 50%;
  transform: translateX(-50%) translateY(10px);
  min-width: 240px;
  background: rgba(20, 18, 18, 0.98);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(222, 168, 130, 0.18);
  border-radius: 4px; padding: 0.85rem 0;
  opacity: 0; visibility: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 18px 45px rgba(0, 0, 0, 0.45);
  z-index: 1001;
}
.header .nav__item:hover .nav__dropdown {
  opacity: 1; visibility: visible;
  transform: translateX(-50%) translateY(0);
}
.header .nav__dropdown-link {
  display: block; padding: 0.75rem 1.5rem;
  font-size: 0.85rem; font-weight: 400;
  color: rgba(255, 255, 255, 0.85);
  text-decoration: none; transition: all 0.2s ease;
  position: relative;
}
.header .nav__dropdown-link::before {
  content: ''; position: absolute; left: 0; top: 50%;
  transform: translateY(-50%); width: 2px; height: 0;
  background: var(--accent-gold, #dea882);
  transition: height 0.2s ease;
}
.header .nav__dropdown-link:hover {
  color: var(--accent-gold, #dea882);
  background: rgba(222, 168, 130, 0.06);
  padding-left: 1.75rem;
}
.header .nav__dropdown-link:hover::before { height: 60%; }

/* Mobile Toggle */
.header .mobile-toggle {
  display: none; flex-direction: column; gap: 6px;
  background: none; border: none; cursor: pointer;
  padding: 12px; min-width: 48px; min-height: 48px;
  align-items: center; justify-content: center;
  z-index: 1003; position: relative;
  -webkit-tap-highlight-color: transparent;
}
.header .mobile-toggle span {
  width: 24px; height: 1px; background: #ffffff;
  transition: all 0.3s ease; transform-origin: center;
}
.header .mobile-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(6px, 6px); }
.header .mobile-toggle.active span:nth-child(2) { opacity: 0; transform: translateX(-10px); }
.header .mobile-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(6px, -6px); }

.header .nav-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.55); z-index: 1001;
  opacity: 0; transition: opacity 0.3s ease;
}
.header .nav-overlay.active { display: block; opacity: 1; }

@media (max-width: 992px) {
  .header .nav {
    position: fixed; top: 0; left: 0; right: 0;
    width: 100%; height: 100vh; height: 100dvh;
    background: rgba(28, 26, 26, 0.99);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    flex-direction: column; justify-content: flex-start; align-items: stretch;
    padding-top: 20px; gap: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform: translateX(100%); opacity: 0;
    padding-left: 24px; padding-right: 24px; padding-bottom: 2rem;
    overflow-y: auto; -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain; z-index: 1002; display: flex;
  }
  .header .nav.nav--open { transform: translateX(0); opacity: 1; }
  .header .nav__link { font-size: 1.1rem; font-weight: 500; padding: 1rem 0; width: 100%; text-align: left; border-bottom: 1px solid rgba(255, 255, 255, 0.08); letter-spacing: 0.08em; }
  .header .nav__item { width: 100%; text-align: left; border-bottom: 1px solid rgba(255, 255, 255, 0.08); cursor: pointer; -webkit-tap-highlight-color: transparent; }
  .header .nav__item-link { font-size: 1.1rem; font-weight: 500; display: flex; justify-content: space-between; align-items: center; padding: 1rem 0; width: 100%; letter-spacing: 0.08em; -webkit-tap-highlight-color: transparent; touch-action: manipulation; user-select: none; -webkit-user-select: none; }
  .header .nav__dropdown { position: static; transform: none; left: auto; top: auto; width: 100%; min-width: 100%; margin-top: 0; background: rgba(255, 255, 255, 0.04); border: none; border-radius: 0; padding: 0; max-height: 0; opacity: 0; visibility: hidden; overflow: hidden; box-shadow: none; backdrop-filter: none; -webkit-backdrop-filter: none; transition: max-height 0.15s ease-out, opacity 0.1s ease-out; }
  .header .nav__item:hover .nav__dropdown,
  .header .nav__item.open .nav__dropdown { position: static; transform: none; left: auto; }
  .header .nav__item.open .nav__dropdown { max-height: 500px; opacity: 1; visibility: visible; padding: 0.5rem 0 0.75rem 0; transition: max-height 0.2s ease-in, opacity 0.1s ease-in; }
  .header .nav__item:hover .nav__dropdown { opacity: 0; visibility: hidden; max-height: 0; }
  .header .nav__item.open:hover .nav__dropdown { opacity: 1; visibility: visible; max-height: 500px; }
  .header .nav__item-link .dropdown-arrow { transition: transform 0.3s ease; }
  .header .nav__item:hover .dropdown-arrow { transform: none; }
  .header .nav__item.open .nav__item-link .dropdown-arrow,
  .header .nav__item.open:hover .dropdown-arrow { transform: rotate(180deg); }
  .header .nav__dropdown-link { text-align: left; padding: 0.75rem 0 0.75rem 1rem; font-size: 0.95rem; font-weight: 400; display: block; color: rgba(255, 255, 255, 0.65); border-left: 2px solid transparent; transition: all 0.2s ease; }
  .header .nav__dropdown-link:hover, .header .nav__dropdown-link:active { color: var(--accent-gold, #dea882); border-left-color: var(--accent-gold, #dea882); background: transparent; padding-left: 1.25rem; }
  .header .nav__dropdown-link::before { display: none; }
  .header .mobile-toggle { display: flex; }
  .header .nav__icons { position: relative; z-index: 1003; }
  .header .nav__mobile-header { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 1rem 0 1.5rem 0; margin-bottom: 0.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
  .header .nav__mobile-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 400; color: #fff; letter-spacing: 0.04em; font-style: italic; }
  .header .nav__mobile-close { background: none; border: none; color: rgba(255, 255, 255, 0.8); cursor: pointer; padding: 8px; margin-right: -8px; display: flex; align-items: center; justify-content: center; transition: color 0.2s ease; }
  .header .nav__mobile-close:hover { color: var(--accent-gold, #dea882); }
}

@media (min-width: 993px) {
  .header .nav__mobile-header { display: none; }
}
</style>

<header class="header {% if section.settings.enable_sticky %}header--sticky{% endif %}" id="header">
  <div class="nav-overlay" id="navOverlay"></div>
  <div class="container">
    <div class="header__inner">
      <a href="{{ routes.root_url }}" class="logo">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 220 }}" alt="{{ shop.name }}" width="220" height="auto">
        {%- else -%}
          {%- comment -%} TODO: Upload via Shopify admin: logo-header.png (or use the LMNY shop_image already in settings_data). {%- endcomment -%}
          <img src="{{ 'logo.svg' | asset_url }}" alt="Laura Milman" height="64" width="auto">
        {%- endif -%}
      </a>

      <nav class="nav" id="nav">
        <div class="nav__mobile-header">
          <span class="nav__mobile-title">Atelier</span>
          <button class="nav__mobile-close" id="navClose" aria-label="Close menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        {%- for link in section.settings.menu.links -%}
          {%- if link.links != blank -%}
            <div class="nav__item">
              <a href="{{ link.url }}" class="nav__item-link">
                {{ link.title }}
                <svg class="dropdown-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </a>
              <div class="nav__dropdown">
                {%- for child_link in link.links -%}
                  <a href="{{ child_link.url }}" class="nav__dropdown-link">{{ child_link.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="nav__link {% if link.active %}nav__link--active{% endif %}">
              {{ link.title }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      <div class="nav__icons">
        <button type="button" class="nav__icon" id="searchToggle" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </button>
        <a href="{{ routes.account_url }}" class="nav__icon" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
        <a href="{{ routes.cart_url }}" class="nav__icon cart-icon" aria-label="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
            <path d="M3 6h18"></path>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="cart-count">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>

      <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Search Overlay -->
<div class="search-overlay" id="searchOverlay">
  <div class="search-overlay__inner">
    <button type="button" class="search-overlay__close" id="searchClose" aria-label="Close search">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <form action="{{ routes.search_url }}" method="get" class="search-overlay__form" role="search">
      <input type="hidden" name="type" value="product">
      <div class="search-overlay__input-wrap">
        <svg class="search-overlay__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          type="search"
          name="q"
          class="search-overlay__input"
          id="searchInput"
          placeholder="Search heirloom rings, pendants, the archive…"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        >
      </div>
    </form>
    <div class="search-overlay__results" id="searchResults"></div>
    <div class="search-overlay__links">
      <p class="search-overlay__label">Frequently sought</p>
      <div class="search-overlay__tags">
        <a href="{{ routes.search_url }}?q=engagement+ring&type=product" class="search-overlay__tag">Engagement Rings</a>
        <a href="{{ routes.search_url }}?q=pendant&type=product" class="search-overlay__tag">Pendants</a>
        <a href="{{ routes.search_url }}?q=necklace&type=product" class="search-overlay__tag">Necklaces</a>
        <a href="{{ routes.search_url }}?q=earring&type=product" class="search-overlay__tag">Earrings</a>
        <a href="{{ routes.search_url }}?q=bracelet&type=product" class="search-overlay__tag">Bracelets</a>
        <a href="/collections/diamonds" class="search-overlay__tag">Loose Diamonds</a>
      </div>
    </div>
  </div>
</div>

<style>
.search-overlay {
  position: fixed; inset: 0; z-index: 2000;
  background: rgba(28, 26, 26, 0.97);
  backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
  display: flex; align-items: flex-start; justify-content: center;
  padding-top: 15vh;
  opacity: 0; visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.search-overlay.active { opacity: 1; visibility: visible; }
.search-overlay__inner { width: 100%; max-width: 680px; padding: 0 2rem; transform: translateY(20px); transition: transform 0.3s ease; }
.search-overlay.active .search-overlay__inner { transform: translateY(0); }
.search-overlay__close { position: absolute; top: 2rem; right: 2rem; background: none; border: none; color: rgba(255, 255, 255, 0.7); cursor: pointer; padding: 0.5rem; transition: color 0.2s ease, transform 0.2s ease; }
.search-overlay__close:hover { color: var(--accent-gold, #dea882); transform: rotate(90deg); }
.search-overlay__form { width: 100%; }
.search-overlay__input-wrap { display: flex; align-items: center; gap: 1rem; border-bottom: 1px solid rgba(255, 255, 255, 0.22); padding-bottom: 0.75rem; transition: border-color 0.3s ease; }
.search-overlay__input-wrap:focus-within { border-color: var(--accent-gold, #dea882); }
.search-overlay__icon { color: rgba(255, 255, 255, 0.5); flex-shrink: 0; }
.search-overlay__input { width: 100%; background: none; border: none; outline: none; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2rem; font-weight: 400; color: #fff; letter-spacing: 0.02em; font-style: italic; }
.search-overlay__input::placeholder { color: rgba(255, 255, 255, 0.32); font-style: italic; }
.search-overlay__results { margin-top: 1.5rem; max-height: 40vh; overflow-y: auto; }
.search-overlay__result-item { display: flex; align-items: center; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid rgba(255, 255, 255, 0.06); text-decoration: none; transition: opacity 0.2s ease; }
.search-overlay__result-item:hover { opacity: 0.82; }
.search-overlay__result-img { width: 56px; height: 56px; object-fit: cover; border-radius: 4px; background: rgba(255, 255, 255, 0.04); }
.search-overlay__result-info { flex: 1; min-width: 0; }
.search-overlay__result-title { font-size: 0.95rem; font-weight: 500; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.search-overlay__result-price { font-size: 0.85rem; color: var(--accent-gold, #dea882); margin-top: 0.15rem; }
.search-overlay__no-results { padding: 1.5rem 0; color: rgba(255, 255, 255, 0.5); font-size: 0.95rem; }
.search-overlay__links { margin-top: 2.5rem; }
.search-overlay__label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.25em; color: rgba(255, 255, 255, 0.42); margin-bottom: 1rem; }
.search-overlay__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.search-overlay__tag { display: inline-block; padding: 0.55rem 1.25rem; font-size: 0.78rem; font-weight: 500; color: rgba(255, 255, 255, 0.78); text-decoration: none; border: 1px solid rgba(255, 255, 255, 0.14); border-radius: 100px; transition: all 0.2s ease; letter-spacing: 0.04em; }
.search-overlay__tag:hover { color: var(--accent-gold, #dea882); border-color: var(--accent-gold, #dea882); background: rgba(222, 168, 130, 0.06); }
#searchToggle { background: none; border: none; cursor: pointer; padding: 0; }
@media (max-width: 768px) {
  .search-overlay { padding-top: 8vh; }
  .search-overlay__input { font-size: 1.4rem; }
  .search-overlay__inner { padding: 0 1.25rem; }
  .search-overlay__close { top: 1.25rem; right: 1.25rem; }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const header = document.getElementById('header');
    var headerScrollTicking = false;
    function handleScroll() {
      if (window.scrollY > 50) header.classList.add('header--scrolled');
      else header.classList.remove('header--scrolled');
    }
    window.addEventListener('scroll', function() {
      if (!headerScrollTicking) {
        window.requestAnimationFrame(function() { handleScroll(); headerScrollTicking = false; });
        headerScrollTicking = true;
      }
    }, { passive: true });
    handleScroll();

    const mobileToggle = document.getElementById('mobileToggle');
    const nav = document.getElementById('nav');
    const navOverlay = document.getElementById('navOverlay');

    function isMobile() { return window.innerWidth <= 992; }
    function openMobileMenu() {
      nav.classList.add('nav--open');
      mobileToggle.classList.add('active');
      navOverlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    function closeMobileMenu() {
      nav.classList.remove('nav--open');
      mobileToggle.classList.remove('active');
      navOverlay.classList.remove('active');
      document.body.style.overflow = '';
      nav.querySelectorAll('.nav__item.open').forEach(function(item) { item.classList.remove('open'); });
    }

    const navClose = document.getElementById('navClose');

    if (mobileToggle && nav) {
      mobileToggle.addEventListener('click', function() {
        if (nav.classList.contains('nav--open')) closeMobileMenu();
        else openMobileMenu();
      });
      if (navClose) navClose.addEventListener('click', closeMobileMenu);
      if (navOverlay) navOverlay.addEventListener('click', closeMobileMenu);

      var touchedDropdown = false;
      nav.querySelectorAll('.nav__item').forEach(function(item) {
        var parentLink = item.querySelector('.nav__item-link');
        if (parentLink) {
          function toggleDropdown() {
            nav.querySelectorAll('.nav__item.open').forEach(function(openItem) {
              if (openItem !== item) openItem.classList.remove('open');
            });
            item.classList.toggle('open');
          }
          parentLink.addEventListener('touchstart', function(e) {
            if (isMobile()) { e.preventDefault(); touchedDropdown = true; toggleDropdown(); }
          }, { passive: false });
          parentLink.addEventListener('click', function(e) {
            if (isMobile()) {
              e.preventDefault();
              if (touchedDropdown) { touchedDropdown = false; return; }
              toggleDropdown();
            }
          });
        }
      });
      nav.querySelectorAll('.nav__dropdown-link').forEach(function(link) {
        link.addEventListener('click', function() { if (isMobile()) closeMobileMenu(); });
      });
      nav.querySelectorAll('.nav__link').forEach(function(link) {
        link.addEventListener('click', function() { if (isMobile()) closeMobileMenu(); });
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && nav.classList.contains('nav--open')) closeMobileMenu();
      });
    }

    var searchToggle = document.getElementById('searchToggle');
    var searchOverlay = document.getElementById('searchOverlay');
    var searchClose = document.getElementById('searchClose');
    var searchInput = document.getElementById('searchInput');
    var searchResults = document.getElementById('searchResults');
    var searchLinks = searchOverlay ? searchOverlay.querySelector('.search-overlay__links') : null;
    var searchDebounce = null;

    function openSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      setTimeout(function() { searchInput.focus(); }, 100);
    }
    function closeSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.remove('active');
      document.body.style.overflow = '';
      searchInput.value = '';
      searchResults.innerHTML = '';
      if (searchLinks) searchLinks.style.display = '';
    }

    if (searchToggle) searchToggle.addEventListener('click', function(e) { e.preventDefault(); openSearch(); });
    if (searchClose) searchClose.addEventListener('click', closeSearch);
    if (searchOverlay) searchOverlay.addEventListener('click', function(e) { if (e.target === searchOverlay) closeSearch(); });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchOverlay && searchOverlay.classList.contains('active')) closeSearch();
    });

    if (searchInput) {
      searchInput.addEventListener('input', function() {
        var q = searchInput.value.trim();
        clearTimeout(searchDebounce);
        if (q.length < 2) {
          searchResults.innerHTML = '';
          if (searchLinks) searchLinks.style.display = '';
          return;
        }
        searchDebounce = setTimeout(function() {
          fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=6')
            .then(function(r) { return r.json(); })
            .then(function(data) {
              var products = (data.resources && data.resources.results && data.resources.results.products) || [];
              if (searchLinks) searchLinks.style.display = products.length > 0 || q.length >= 2 ? 'none' : '';
              if (products.length === 0) {
                searchResults.innerHTML = '<p class="search-overlay__no-results">No pieces match “' + q.replace(/</g, '&lt;') + '” yet.</p>';
                return;
              }
              var html = '';
              products.forEach(function(p) {
                var img = p.image || '';
                var price = p.price;
                if (typeof price === 'string') price = parseFloat(price);
                var formattedPrice = '$' + (price / 1).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                html += '<a href="' + p.url + '" class="search-overlay__result-item">';
                if (img) html += '<img class="search-overlay__result-img" src="' + img.replace(/(\.\w+)$/, '_200x$1') + '" alt="" loading="lazy">';
                html += '<div class="search-overlay__result-info">';
                html += '<div class="search-overlay__result-title">' + p.title + '</div>';
                html += '<div class="search-overlay__result-price">' + formattedPrice + '</div>';
                html += '</div></a>';
              });
              searchResults.innerHTML = html;
            })
            .catch(function() { searchResults.innerHTML = ''; });
        }, 300);
      });
    }
  });
</script>

