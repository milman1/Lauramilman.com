  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "link_list", "id": "menu", "default": "main-menu", "label": "Menu" },
    { "type": "checkbox", "id": "enable_sticky", "default": true, "label": "Enable sticky header" }
  ]
}
