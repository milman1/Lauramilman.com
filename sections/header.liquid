            <a href="/collections/david-webb"       class="nav-dropdown__item" role="menuitem">David Webb</a>
            <a href="/collections/graff"            class="nav-dropdown__item" role="menuitem">Graff</a>
            <a href="/collections/harry-winston"    class="nav-dropdown__item" role="menuitem">Harry Winston</a>
            <a href="/collections/hermes"           class="nav-dropdown__item" role="menuitem">Hermès</a>
            <a href="/collections/marina-b"         class="nav-dropdown__item" role="menuitem">Marina B.</a>
            <a href="/collections/tiffany-co"       class="nav-dropdown__item" role="menuitem">Tiffany &amp; Co.</a>
