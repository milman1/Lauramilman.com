<script>
document.addEventListener('DOMContentLoaded', function() {
  /* ===================================================
     CLIENT-SIDE PRODUCT FILTERING
     All filtering happens instantly without page reload.
     Products are shown/hidden based on data attributes.
     =================================================== */

  const productsGrid = document.getElementById('productsGrid');
  const noResultsEl = document.getElementById('filterNoResults');
  const resultsCountEl = document.querySelector('.results-count');
  const allCards = productsGrid ? Array.from(productsGrid.querySelectorAll('.product-card-wrapper')) : [];

  /* ---------- Helper: extract carat number from title ---------- */
  function extractCaratFromTitle(title) {
    // Match patterns like "5.0 Carat", "1.53 ct", "4.69 Carat"
    const match = title.match(/([\d.]+)\s*(?:carat|ct)/i);
    return match ? parseFloat(match[1]) : null;
  }

  /* ---------- Helper: check if carat is in range ---------- */
  function caratInRange(carat, rangeKey) {
    if (carat === null) return false;
    switch (rangeKey) {
      case 'Under 0.5 Carats': return carat < 0.5;
      case '0.5-1 Carats':     return carat >= 0.5 && carat < 1;
      case 'Under 1 Carat':    return carat < 1;
      case '1-2 Carats':       return carat >= 1 && carat < 2;
      case 'Under 2 Carats':   return carat < 2;
      case '2-3 Carats':       return carat >= 2 && carat < 3;
      case 'Under 3 Carats':   return carat < 3;
      case '3-4 Carats':       return carat >= 3 && carat < 4;
      case '3-5 Carats':       return carat >= 3 && carat < 5;
      case '4-5 Carats':       return carat >= 4 && carat < 5;
      case '5-7 Carats':       return carat >= 5 && carat < 7;
      case '5+ Carats':        return carat >= 5;
      case '3+ Carats':        return carat >= 3;
      case '7-10 Carats':      return carat >= 7 && carat < 10;
      case '7+ Carats':        return carat >= 7;
      case '10+ Carats':       return carat >= 10;
      default: return false;
    }
  }

  /* ---------- Main filter function ---------- */
  function applyFilters() {
    // 1. Collect selected metal types
    var selectedMetals = [];
    document.querySelectorAll('.metal-option input:checked').forEach(function(input) {
      selectedMetals.push(input.value.toLowerCase());
    });

    // 2. Collect selected carat range
    var activeCarat = document.querySelector('.carat-btn.active');
    var caratRange = activeCarat ? activeCarat.dataset.carat : null;

    // 3. Collect selected diamond shapes
    var selectedShapes = [];
    document.querySelectorAll('.style-option input[name="shape"]:checked').forEach(function(input) {
      selectedShapes.push(input.value.toLowerCase());
    });

    // 4. Collect selected jewelry types
    var selectedTypes = [];
    document.querySelectorAll('.style-option input[name="type"]:checked').forEach(function(input) {
      selectedTypes.push(input.value.toLowerCase());
    });

    // 5. Get price range
    var minPriceVal = document.getElementById('minPrice').value.replace(/[^0-9.]/g, '');
    var maxPriceVal = document.getElementById('maxPrice').value.replace(/[^0-9.]/g, '');
    var minPrice = minPriceVal ? parseFloat(minPriceVal) : null;
    var maxPrice = maxPriceVal ? parseFloat(maxPriceVal) : null;

    var visibleCount = 0;
    var hasActiveFilters = selectedMetals.length > 0 || caratRange || selectedShapes.length > 0 || selectedTypes.length > 0 || minPrice !== null || maxPrice !== null;

    allCards.forEach(function(card) {
      var tags = card.dataset.tags || '';          // already lowercase, separated by |||
      var titleLower = card.dataset.titleLower || '';
      var title = card.dataset.title || '';
      var productType = card.dataset.type || '';
      var priceCents = parseInt(card.dataset.priceCents || '0', 10);
      var priceDollars = priceCents / 100;

      var show = true; // default: show

      // --- Metal filter (OR logic: product matches if ANY selected metal is in tags/title) ---
      if (show && selectedMetals.length > 0) {
        var metalMatch = selectedMetals.some(function(metal) {
          return tags.indexOf(metal) !== -1 || titleLower.indexOf(metal) !== -1;
        });
        if (!metalMatch) show = false;
      }

      // --- Carat weight filter ---
      if (show && caratRange) {
        var carat = extractCaratFromTitle(title);
        if (!caratInRange(carat, caratRange)) show = false;
      }

      // --- Diamond Shape filter (OR logic) ---
      if (show && selectedShapes.length > 0) {
        var shapeMatch = selectedShapes.some(function(shape) {
          return tags.indexOf(shape) !== -1 || titleLower.indexOf(shape) !== -1;
        });
        if (!shapeMatch) show = false;
      }

      // --- Jewelry Type filter (OR logic) ---
      if (show && selectedTypes.length > 0) {
        var typeMatch = selectedTypes.some(function(type) {
          return tags.indexOf(type) !== -1 || titleLower.indexOf(type) !== -1 || productType.indexOf(type) !== -1;
        });
        if (!typeMatch) show = false;
      }

      // --- Price filter ---
      if (show && minPrice !== null && priceDollars < minPrice) show = false;
      if (show && maxPrice !== null && priceDollars > maxPrice) show = false;

      // Show or hide
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    // Update results count
    if (resultsCountEl) {
      resultsCountEl.innerHTML = 'Showing <strong>' + visibleCount + '</strong> of ' + allCards.length + ' pieces';
    }

    // Show/hide no-results message
    if (noResultsEl) {
      noResultsEl.style.display = (visibleCount === 0 && hasActiveFilters) ? 'block' : 'none';
    }

    // Update mobile filter badge
    var activeCount = selectedMetals.length + (caratRange ? 1 : 0) + selectedShapes.length + selectedTypes.length + (minPrice !== null ? 1 : 0) + (maxPrice !== null ? 1 : 0);
    var mobileToggleBtn = document.getElementById('mobileFilterToggle');
    if (mobileToggleBtn) {
      if (activeCount > 0) {
        mobileToggleBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg> Refine <span class="active-filters-count">' + activeCount + '</span>';
      } else {
        mobileToggleBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg> Refine';
      }
    }
  }

  /* ---------- Clear all filters ---------- */
  function clearAllFilters() {
    // Uncheck all metal types
    document.querySelectorAll('.metal-option input').forEach(function(input) {
      input.checked = false;
      input.closest('.metal-option').classList.remove('active');
    });

    // Deactivate all carat buttons
    document.querySelectorAll('.carat-btn').forEach(function(btn) {
      btn.classList.remove('active');
    });

    // Uncheck all shape & type checkboxes
    document.querySelectorAll('.style-option input').forEach(function(input) {
      input.checked = false;
      input.closest('.style-option').classList.remove('active');
    });

    // Clear price inputs
    document.getElementById('minPrice').value = '';
    document.getElementById('maxPrice').value = '';

    applyFilters();
  }

  /* ===================================================
     UI EVENT BINDINGS
     =================================================== */

  // Filter section toggle (accordion)
  document.querySelectorAll('.filter-section__header').forEach(function(header) {
    header.addEventListener('click', function() {
      this.closest('.filter-section').classList.toggle('collapsed');
    });
  });

  // Metal type selection — toggle checkbox + apply instantly
  document.querySelectorAll('.metal-option').forEach(function(option) {
    option.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var checkbox = this.querySelector('input[type="checkbox"]');
      if (checkbox) {
        checkbox.checked = !checkbox.checked;
        this.classList.toggle('active', checkbox.checked);
      }
      applyFilters();
    });
  });

  // Carat weight buttons (single select) — apply instantly
  document.querySelectorAll('.carat-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var wasActive = this.classList.contains('active');
      document.querySelectorAll('.carat-btn').forEach(function(b) {
        b.classList.remove('active');
      });
      if (!wasActive) this.classList.add('active');
      applyFilters();
    });
  });

  // Style/Shape/Type checkboxes — apply instantly
  document.querySelectorAll('.style-option').forEach(function(option) {
    var checkbox = option.querySelector('input');
    option.addEventListener('click', function(e) {
      if (e.target.tagName !== 'INPUT') {
        checkbox.checked = !checkbox.checked;
      }
      this.classList.toggle('active', checkbox.checked);
      applyFilters();
    });
  });

  // Price range — apply on Enter key or blur
  var minPriceInput = document.getElementById('minPrice');
  var maxPriceInput = document.getElementById('maxPrice');
  
  function handlePriceChange(e) {
    if (e.type === 'keydown' && e.key !== 'Enter') return;
    applyFilters();
  }
  
  if (minPriceInput) {
    minPriceInput.addEventListener('keydown', handlePriceChange);
    minPriceInput.addEventListener('blur', function() { applyFilters(); });
  }
  if (maxPriceInput) {
    maxPriceInput.addEventListener('keydown', handlePriceChange);
    maxPriceInput.addEventListener('blur', function() { applyFilters(); });
  }

  // Apply Filters button (also works)
  var filterForm = document.getElementById('jewelryFilterForm');
  if (filterForm) {
    filterForm.addEventListener('submit', function(e) {
      e.preventDefault();
      applyFilters();
      // On mobile, close the filter panel after applying
      var sidebar = document.getElementById('sidebarFilters');
      if (sidebar && sidebar.classList.contains('open')) {
        sidebar.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
  }

  // Clear All Filters buttons
  document.querySelectorAll('.filter-clear-btn, #clearAllFiltersBtn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      clearAllFilters();
    });
  });

  /* ===================================================
     MOBILE FILTER PANEL
     =================================================== */
  var mobileToggle = document.getElementById('mobileFilterToggle');
  var sidebar = document.getElementById('sidebarFilters');
  var closeBtn = document.getElementById('closeFilters');
  var mobileCloseHeader = document.querySelector('.mobile-filter-close');

  if (mobileToggle && sidebar) {
    if (window.innerWidth <= 992 && mobileCloseHeader) {
      mobileCloseHeader.style.display = 'flex';
    }
    mobileToggle.addEventListener('click', function() {
      sidebar.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        sidebar.classList.remove('open');
        document.body.style.overflow = '';
      });
    }
  }
});
</script>

