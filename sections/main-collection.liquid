  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 12,
      "label": "Products per page"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "default": true,
      "label": "Show filters"
    },
    {
      "type": "checkbox",
      "id": "show_metal_filter",
      "default": true,
      "label": "Show metal type filter"
    },
    {
      "type": "checkbox",
      "id": "show_carat_filter",
      "default": true,
      "label": "Show carat weight filter"
    },
    {
      "type": "checkbox",
      "id": "show_style_filter",
      "default": true,
      "label": "Show style filter"
    }
  ]
}
{% endschema %}
