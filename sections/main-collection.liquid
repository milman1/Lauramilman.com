          <div class="collection-empty text-center" style="padding: 4rem;">
            <h3>No products found</h3>
            <p class="text-muted">Try adjusting your filters or browse our full collection.</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">View All Products</a>
