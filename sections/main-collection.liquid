{%- comment -%}
  Main Collection Section - Displays product grid for collection pages
  Enhanced filters for jewelry: Metal Type, Carat Weight, Style
{%- endcomment -%}

<style>
  /* Ensure collection section is below the fixed header */
  .collection-section {
    padding-top: 120px;
  }
  
  .collection-header {
    padding-top: 2rem;
  }
  
  .jewelry-filters {
    background: var(--bg-white, #fff);
    border-radius: 12px;
    padding: 1.5rem;
  }
  
  .jewelry-filters h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--primary-navy, #1a1f3a);
    border-bottom: 1px solid var(--border-light, #e5e7eb);
    padding-bottom: 1rem;
  }
  
  .filter-section {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-light, #e5e7eb);
  }
  
  .filter-section:last-of-type {
    border-bottom: none;
    margin-bottom: 0;
  }
  
  .filter-section__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    padding: 0.5rem 0;
  }
  
  .filter-section__title {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #1a1a1a;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .filter-section__title svg {
    width: 16px;
    height: 16px;
    color: var(--accent-gold, #c9a962);
  }
  
  .filter-section__toggle {
    transition: transform 0.3s ease;
  }
  
  .filter-section.collapsed .filter-section__toggle {
    transform: rotate(-90deg);
  }
  
  .filter-section__content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.75rem;
    width: 100%;
    overflow: hidden;
  }
  
  .filter-section.collapsed .filter-section__content {
    display: none;
  }
  
  /* Metal Type Pills */
  .metal-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .metal-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 2px solid var(--border-light, #e5e7eb);
    border-radius: 25px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: var(--bg-white, #fff);
    position: relative;
    user-select: none;
  }
  
  .metal-option:hover {
    border-color: var(--accent-gold, #c9a962);
  }
  
  .metal-option.active {
    border-color: var(--accent-gold, #c9a962);
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.1) 0%, rgba(201, 169, 98, 0.05) 100%);
  }
  
  .metal-option input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  
  .metal-swatch {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.1);
  }
  
  .metal-swatch--yellow-gold { background: linear-gradient(135deg, #FFD700 0%, #DAA520 100%); }
  .metal-swatch--white-gold { background: linear-gradient(135deg, #E8E8E8 0%, #C0C0C0 100%); }
  .metal-swatch--rose-gold { background: linear-gradient(135deg, #E8B4B8 0%, #B76E79 100%); }
  .metal-swatch--platinum { background: linear-gradient(135deg, #E5E4E2 0%, #B4B4B4 100%); }
  .metal-swatch--silver { background: linear-gradient(135deg, #C0C0C0 0%, #A8A8A8 100%); }
  
  .metal-option span {
    font-size: 0.8rem;
    color: #1a1a1a;
    font-weight: 500;
  }
  
  /* Carat Weight Slider */
  .carat-range {
    padding: 0.5rem 0;
  }
  
  .carat-buttons {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }
  
  .carat-btn {
    padding: 0.6rem 0.75rem;
    border: 2px solid var(--border-light, #e5e7eb);
    border-radius: 8px;
    background: var(--bg-white, #fff);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }
  
  .carat-btn:hover {
    border-color: var(--accent-gold, #c9a962);
  }
  
  .carat-btn.active {
    border-color: var(--accent-gold, #c9a962);
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.1) 0%, rgba(201, 169, 98, 0.05) 100%);
    color: var(--accent-gold-dark, #b89a4d);
    font-weight: 600;
  }
  
  /* Style Type Grid */
  .style-options {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  
  .style-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .style-option:hover {
    background: var(--bg-light, #f5f4f2);
  }
  
  .style-option.active {
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.1) 0%, rgba(201, 169, 98, 0.05) 100%);
  }
  
  .style-option input {
    appearance: none;
    width: 18px;
    height: 18px;
    border: 2px solid var(--border-medium, #d1d5db);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
  }
  
  .style-option input:checked {
    background: var(--accent-gold, #c9a962);
    border-color: var(--accent-gold, #c9a962);
  }
  
  .style-option input:checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 4px;
    height: 8px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  
  .style-option span {
    font-size: 0.875rem;
    color: #1a1a1a;
    font-weight: 500;
  }
  
  /* Price Range */
  .price-inputs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    box-sizing: border-box;
  }
  
  .price-input {
    flex: 1;
    min-width: 0;
    max-width: calc(50% - 1rem);
    padding: 0.5rem 0.5rem;
    border: 2px solid var(--border-light, #e5e7eb);
    border-radius: 8px;
    font-size: 0.8rem;
    text-align: center;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }
  
  .price-input:focus {
    outline: none;
    border-color: var(--accent-gold, #c9a962);
  }
  
  .price-separator {
    color: var(--text-muted, #6b7280);
    font-weight: 500;
    flex-shrink: 0;
  }
  
  /* Apply Button */
  .filter-apply-btn {
    width: 100%;
    padding: 1rem;
    background: var(--primary-navy, #1a1f3a);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 1rem;
  }
  
  .filter-apply-btn:hover {
    background: var(--primary-navy-light, #2a3152);
    transform: translateY(-2px);
  }
  
  .filter-clear-btn {
    width: 100%;
    padding: 0.75rem;
    background: transparent;
    color: var(--text-muted, #6b7280);
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 8px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 0.5rem;
  }
  
  .filter-clear-btn:hover {
    border-color: var(--text-muted, #6b7280);
    color: var(--text-dark, #1a1f3a);
  }
  
  /* Active filters badge */
  .active-filters-count {
    background: var(--accent-gold, #c9a962);
    color: var(--primary-navy, #1a1f3a);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 10px;
    margin-left: auto;
  }
  
  /* Mobile filter toggle */
  .mobile-filter-toggle {
    display: none;
    width: 100%;
    padding: 1rem;
    background: var(--bg-white, #fff);
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 8px;
    margin-bottom: 1rem;
    font-weight: 500;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  
  @media (max-width: 992px) {
    .collection-section {
      padding-top: 80px;
    }
    
    .collection-header h1 {
      font-size: 1.75rem !important;
    }
    
    .mobile-filter-toggle {
      display: flex;
      font-size: 0.9rem;
      padding: 0.875rem;
    }
    
    .sidebar-filters {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--bg-white, #fff);
      z-index: 1100;
      overflow-y: auto;
      padding: 1rem;
    }
    
    .sidebar-filters.open {
      display: block;
    }
    
    .mobile-filter-close {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 0;
      margin-bottom: 1rem;
      border-bottom: 1px solid var(--border-light, #e5e7eb);
    }
    
    .mobile-filter-close h3 {
      margin: 0;
      font-size: 1.25rem;
    }
    
    .mobile-filter-close button {
      background: none;
      border: none;
      font-size: 2rem;
      cursor: pointer;
      padding: 0.5rem;
      line-height: 1;
    }
    
    .listing-layout {
      display: block;
    }
    
    .products-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 12px !important;
    }
    
    .results-header {
      flex-direction: column;
      gap: 12px;
      align-items: stretch !important;
    }
    
    .results-count {
      text-align: center;
    }
    
    .sort-dropdown {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    
    .sort-dropdown select {
      width: 100%;
      padding: 10px;
      font-size: 0.9rem;
    }
  }
  
  @media (max-width: 480px) {
    .collection-section {
      padding-top: 70px;
    }
    
    .collection-header {
      margin-bottom: 1rem !important;
    }
    
    .collection-header h1 {
      font-size: 1.5rem !important;
      margin-bottom: 0.25rem !important;
    }
    
    .collection-header p {
      font-size: 0.85rem !important;
    }
    
    .products-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 8px !important;
    }
    
    .mobile-filter-toggle {
      padding: 0.75rem;
      font-size: 0.85rem;
      margin-bottom: 0.75rem;
    }
    
    /* Compact filter options on mobile */
    .metal-options {
      gap: 0.375rem;
    }
    
    .metal-option {
      padding: 0.4rem 0.75rem;
      font-size: 0.75rem;
    }
    
    .metal-swatch {
      width: 14px;
      height: 14px;
    }
    
    .carat-buttons {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.375rem;
    }
    
    .carat-btn {
      padding: 0.5rem;
      font-size: 0.75rem;
    }
    
    .style-option {
      padding: 0.5rem;
    }
    
    .style-option span {
      font-size: 0.8rem;
    }
    
    .filter-apply-btn {
      padding: 0.875rem;
      font-size: 0.85rem;
    }
  }

  /* Layout grid (sidebar + products) — ported from Peaceful Diamonds theme.css */
  .listing-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    align-items: flex-start;
  }
  .sidebar-filters {
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }
  .products-results {
    min-width: 0;
  }
  .results-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-light, #e5e7eb);
    gap: 12px;
    flex-wrap: wrap;
  }
  .results-count {
    color: var(--text-muted, #6b7280);
    font-size: 0.95rem;
  }
  .sort-dropdown {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sort-dropdown label {
    font-size: 0.875rem;
    color: var(--text-muted, #6b7280);
  }
  .sort-dropdown select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 8px;
    background: #fff;
    font-size: 0.875rem;
    cursor: pointer;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }
  .pagination a, .pagination span {
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-dark, #1a1f3a);
    font-size: 0.875rem;
  }
  .pagination span[aria-current], .pagination .active {
    background: var(--primary-navy, #1a1f3a);
    color: #fff;
    border-color: var(--primary-navy, #1a1f3a);
  }
  .breadcrumbs { padding: 1rem 0; font-size: 0.875rem; }
  .breadcrumbs__list { list-style: none; display: flex; gap: 0.5rem; padding: 0; margin: 0; }
  .breadcrumbs__item:not(:last-child)::after { content: '/'; margin-left: 0.5rem; color: var(--text-muted, #6b7280); }
  .breadcrumbs__link { color: var(--text-muted, #6b7280); text-decoration: none; }
  .breadcrumbs__link:hover { color: var(--accent-gold, #c9a962); }
  .breadcrumbs__item--current { color: var(--text-dark, #1a1f3a); }
  .container { max-width: 1400px; margin: 0 auto; padding: 0 1.5rem; }
  .section { padding: 2rem 0 4rem; }

  @media (max-width: 992px) {
    .listing-layout { grid-template-columns: 1fr; }
    .sidebar-filters { position: static; max-height: none; }
  }

</style>

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs__list">
    <li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">Home</a></li>
    <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">{{ collection.title }}</li>
  </ol>
</nav>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"{{ shop.url }}"},
    {"@type":"ListItem","position":2,"name":{{ collection.title | json }},"item":"{{ shop.url }}{{ collection.url }}"}
  ]
}
</script>

<section class="collection-section section">
  <div class="container">
    <!-- Collection Header -->
    <div class="collection-header" style="text-align: center; margin-bottom: 2rem;">
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; margin-bottom: 0.5rem;">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">{{ collection.description }}</p>
      {%- endif -%}
    </div>
    
    

    <!-- Mobile Filter Toggle -->
    <button class="mobile-filter-toggle" id="mobileFilterToggle">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
      </svg>
      Filter & Sort
    </button>
    
    <div class="listing-layout">
      <!-- Sidebar Filters -->
      <aside class="sidebar-filters" id="sidebarFilters">
        <!-- Mobile close button -->
        <div class="mobile-filter-close" style="display: none;">
          <h3>Filters</h3>
          <button id="closeFilters" aria-label="Close filters">&times;</button>
        </div>
        
        <form id="jewelryFilterForm" class="jewelry-filters">
          <h3>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            Refine By
          </h3>
          
          <!-- Metal Type Filter -->
          <div class="filter-section" data-filter="metal">
            <div class="filter-section__header">
              <span class="filter-section__title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 2a10 10 0 0 1 0 20"/>
                </svg>
                Metal Type
              </span>
              <svg class="filter-section__toggle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="filter-section__content">
              <div class="metal-options">
                <label class="metal-option" data-metal="Yellow Gold">
                  <input type="checkbox" name="metal" value="Yellow Gold">
                  <span class="metal-swatch metal-swatch--yellow-gold"></span>
                  <span>Yellow Gold</span>
                </label>
                <label class="metal-option" data-metal="White Gold">
                  <input type="checkbox" name="metal" value="White Gold">
                  <span class="metal-swatch metal-swatch--white-gold"></span>
                  <span>White Gold</span>
                </label>
                <label class="metal-option" data-metal="Rose Gold">
                  <input type="checkbox" name="metal" value="Rose Gold">
                  <span class="metal-swatch metal-swatch--rose-gold"></span>
                  <span>Rose Gold</span>
                </label>
                <label class="metal-option" data-metal="Platinum">
                  <input type="checkbox" name="metal" value="Platinum">
                  <span class="metal-swatch metal-swatch--platinum"></span>
                  <span>Platinum</span>
                </label>
              </div>
            </div>
          </div>
          
          <!-- Carat Weight Filter - Dynamic per category -->
          <div class="filter-section" data-filter="carat">
            <div class="filter-section__header">
              <span class="filter-section__title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 3h12l4 6-10 13L2 9z"/>
                  <path d="M12 22V9"/>
                  <path d="m2 9 10 4 10-4"/>
                </svg>
                {%- case collection.handle -%}
                  {%- when 'bracelets', 'tennis-bracelets' -%}
                    Total Carat Weight
                  {%- when 'earrings' -%}
                    Total Carat Weight
                  {%- else -%}
                    Carat Weight
                {%- endcase -%}
              </span>
              <svg class="filter-section__toggle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="filter-section__content">
              <div class="carat-buttons">
                {%- case collection.handle -%}
                  {%- when 'rings', 'engagement-rings' -%}
                    <button type="button" class="carat-btn" data-carat="Under 1 Carat">Under 1 ct</button>
                    <button type="button" class="carat-btn" data-carat="1-2 Carats">1 - 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3-5 Carats">3 - 5 ct</button>
                    <button type="button" class="carat-btn" data-carat="5+ Carats">5+ ct</button>
                  
                  {%- when 'wedding', 'wedding-bands' -%}
                    <button type="button" class="carat-btn" data-carat="Under 0.5 Carats">Under 0.5 ct</button>
                    <button type="button" class="carat-btn" data-carat="0.5-1 Carats">0.5 - 1 ct</button>
                    <button type="button" class="carat-btn" data-carat="1-2 Carats">1 - 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3+ Carats">3+ ct</button>
                  
                  {%- when 'bracelets', 'tennis-bracelets' -%}
                    <button type="button" class="carat-btn" data-carat="Under 3 Carats">Under 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3-5 Carats">3 - 5 ct</button>
                    <button type="button" class="carat-btn" data-carat="5-7 Carats">5 - 7 ct</button>
                    <button type="button" class="carat-btn" data-carat="7-10 Carats">7 - 10 ct</button>
                    <button type="button" class="carat-btn" data-carat="10+ Carats">10+ ct</button>
                  
                  {%- when 'earrings' -%}
                    <button type="button" class="carat-btn" data-carat="Under 0.5 Carats">Under 0.5 ct</button>
                    <button type="button" class="carat-btn" data-carat="0.5-1 Carats">0.5 - 1 ct</button>
                    <button type="button" class="carat-btn" data-carat="1-2 Carats">1 - 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3+ Carats">3+ ct</button>
                  
                  {%- when 'necklaces', 'pendants' -%}
                    <button type="button" class="carat-btn" data-carat="Under 1 Carat">Under 1 ct</button>
                    <button type="button" class="carat-btn" data-carat="1-2 Carats">1 - 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3-5 Carats">3 - 5 ct</button>
                    <button type="button" class="carat-btn" data-carat="5+ Carats">5+ ct</button>
                  
                  {%- else -%}
                    <button type="button" class="carat-btn" data-carat="Under 2 Carats">Under 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3-5 Carats">3 - 5 ct</button>
                    <button type="button" class="carat-btn" data-carat="5-7 Carats">5 - 7 ct</button>
