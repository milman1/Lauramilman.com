{%- comment -%}
  Main Collection Section - Displays product grid for collection pages
  Enhanced filters for jewelry: Metal Type, Carat Weight, Style
{%- endcomment -%}

{%- render 'main-collection-styles' -%}

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs__list">
    <li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">Home</a></li>
    <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">{{ collection.title }}</li>
  </ol>
</nav>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"{{ shop.url }}"},
    {"@type":"ListItem","position":2,"name":{{ collection.title | json }},"item":"{{ shop.url }}{{ collection.url }}"}
  ]
}
</script>

<section class="collection-section section">
  <div class="container">
    <!-- Collection Header -->
    <div class="collection-header" style="text-align: center; margin-bottom: 2rem;">
      <h1 style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 2.5rem; letter-spacing: 0.01em; margin-bottom: 0.5rem;">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">{{ collection.description }}</p>
      {%- endif -%}
    </div>
    
    {%- comment -%} Shop-by sub-navigation — per-category SEO pills {%- endcomment -%}
    {%- case collection.handle -%}

      {%- when 'engagement-rings' -%}
        {%- render 'shop-by-links',
            heading: 'Shop by',
            col_handle_1: 'lab-grown-diamond-engagement-rings-under-5-000',
            col_handle_2: '2ct-oval-lab-grown-engagement-rings',
            col_handle_3: '1-5ct-oval-lab-grown-engagement-rings-copy',
            guide_handle: 'lab-grown-diamond-buying-guide',
            guide_text: 'Need help choosing?'
        -%}

      {%- when 'necklaces' -%}
        {%- render 'shop-by-links',
            heading: 'Shop by',
            url_1: '/collections/necklaces/diamond+pendant',
            label_1: 'Diamond Pendants',
            url_2: '/collections/necklaces/tennis+necklace',
            label_2: 'Tennis Necklaces',
            url_3: '/collections/necklaces/solitaire',
            label_3: 'Solitaire Necklaces',
            url_4: '/collections/necklaces/yellow+gold',
            label_4: 'Yellow Gold Necklaces',
            url_5: '/collections/necklaces/white+gold',
            label_5: 'White Gold Necklaces',
            guide_handle: 'lab-grown-diamond-buying-guide',
            guide_text: 'Need help choosing?'
        -%}

      {%- when 'pendants' -%}
        {%- render 'shop-by-links',
            heading: 'Shop by',
            url_1: '/collections/pendants/round',
            label_1: 'Round Diamond Pendants',
            url_2: '/collections/pendants/oval',
            label_2: 'Oval Diamond Pendants',
            url_3: '/collections/pendants/halo',
            label_3: 'Halo Pendants',
            url_4: '/collections/pendants/yellow+gold',
            label_4: 'Yellow Gold',
            url_5: '/collections/pendants/white+gold',
            label_5: 'White Gold',
            guide_handle: 'lab-grown-diamond-buying-guide',
            guide_text: 'Need help choosing?'
        -%}

      {%- when 'earrings' -%}
        {%- render 'shop-by-links',
            heading: 'Shop by',
            url_1: '/collections/earrings/studs',
            label_1: 'Diamond Studs',
            url_2: '/collections/earrings/hoops',
            label_2: 'Diamond Hoops',
            url_3: '/collections/earrings/drop',
            label_3: 'Drop Earrings',
            url_4: '/collections/earrings/yellow+gold',
            label_4: 'Yellow Gold Earrings',
            url_5: '/collections/earrings/white+gold',
            label_5: 'White Gold Earrings',
            guide_handle: 'lab-grown-diamond-buying-guide',
            guide_text: 'Need help choosing?'
        -%}

      {%- when 'bracelets' -%}
        {%- render 'shop-by-links',
            heading: 'Shop by',
            url_1: '/collections/bracelets/tennis+bracelet',
            label_1: 'Tennis Bracelets',
            url_2: '/collections/bracelets/bangle',
            label_2: 'Diamond Bangles',
            url_3: '/collections/bracelets/yellow+gold',
            label_3: 'Yellow Gold Bracelets',
            url_4: '/collections/bracelets/white+gold',
            label_4: 'White Gold Bracelets',
            url_5: '/collections/bracelets/rose+gold',
            label_5: 'Rose Gold Bracelets',
            guide_handle: 'lab-grown-diamond-buying-guide',
            guide_text: 'Need help choosing?'
        -%}

      {%- when 'wedding-bands' -%}
        {%- render 'shop-by-links',
            heading: 'Shop by',
            url_1: '/collections/wedding-bands/eternity',
            label_1: 'Eternity Bands',
            url_2: '/collections/wedding-bands/half+eternity',
            label_2: 'Half Eternity Bands',
            url_3: '/collections/wedding-bands/yellow+gold',
            label_3: 'Yellow Gold Bands',
            url_4: '/collections/wedding-bands/white+gold',
            label_4: 'White Gold Bands',
            url_5: '/collections/wedding-bands/platinum',
            label_5: 'Platinum Bands',
            guide_handle: 'lab-grown-diamond-buying-guide',
            guide_text: 'Need help choosing?'
        -%}

      {%- when 'ring-settings' -%}
        {%- render 'shop-by-links',
            heading: 'Shop by',
            url_1: '/collections/ring-settings/solitaire',
            label_1: 'Solitaire Settings',
            url_2: '/collections/ring-settings/halo',
            label_2: 'Halo Settings',
            url_3: '/collections/ring-settings/pave',
            label_3: 'Pavé Settings',
            url_4: '/collections/ring-settings/three+stone',
            label_4: 'Three Stone Settings',
            url_5: '/collections/ring-settings/vintage',
            label_5: 'Vintage Settings',
            guide_handle: 'lab-grown-diamond-buying-guide',
            guide_text: 'Need help choosing?'
        -%}

    {%- endcase -%}

    <!-- Mobile Filter Toggle -->
    <button class="mobile-filter-toggle" id="mobileFilterToggle">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
      </svg>
      Refine
    </button>
    
    <div class="listing-layout">
      <!-- Sidebar Filters -->
      <aside class="sidebar-filters" id="sidebarFilters">
        <!-- Mobile close button -->
        <div class="mobile-filter-close" style="display: none;">
          <h3>Refine</h3>
          <button id="closeFilters" aria-label="Close filters">&times;</button>
        </div>
        
        <form id="jewelryFilterForm" class="jewelry-filters">
          <h3>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            Refine By
          </h3>
          
          <!-- Metal Type Filter -->
          <div class="filter-section" data-filter="metal">
            <div class="filter-section__header">
              <span class="filter-section__title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 2a10 10 0 0 1 0 20"/>
                </svg>
                Metal Type
              </span>
              <svg class="filter-section__toggle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="filter-section__content">
              <div class="metal-options">
                <label class="metal-option" data-metal="Yellow Gold">
                  <input type="checkbox" name="metal" value="Yellow Gold">
                  <span class="metal-swatch metal-swatch--yellow-gold"></span>
                  <span>Yellow Gold</span>
                </label>
                <label class="metal-option" data-metal="White Gold">
                  <input type="checkbox" name="metal" value="White Gold">
                  <span class="metal-swatch metal-swatch--white-gold"></span>
                  <span>White Gold</span>
                </label>
                <label class="metal-option" data-metal="Rose Gold">
                  <input type="checkbox" name="metal" value="Rose Gold">
                  <span class="metal-swatch metal-swatch--rose-gold"></span>
                  <span>Rose Gold</span>
                </label>
                <label class="metal-option" data-metal="Platinum">
                  <input type="checkbox" name="metal" value="Platinum">
                  <span class="metal-swatch metal-swatch--platinum"></span>
                  <span>Platinum</span>
                </label>
              </div>
            </div>
          </div>
          
          <!-- Carat Weight Filter - Dynamic per category -->
          <div class="filter-section" data-filter="carat">
            <div class="filter-section__header">
              <span class="filter-section__title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 3h12l4 6-10 13L2 9z"/>
                  <path d="M12 22V9"/>
                  <path d="m2 9 10 4 10-4"/>
                </svg>
                {%- case collection.handle -%}
                  {%- when 'bracelets', 'tennis-bracelets' -%}
                    Total Carat Weight
                  {%- when 'earrings' -%}
                    Total Carat Weight
                  {%- else -%}
                    Carat Weight
                {%- endcase -%}
              </span>
              <svg class="filter-section__toggle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="filter-section__content">
              <div class="carat-buttons">
                {%- case collection.handle -%}
                  {%- when 'rings', 'engagement-rings' -%}
                    <button type="button" class="carat-btn" data-carat="Under 1 Carat">Under 1 ct</button>
                    <button type="button" class="carat-btn" data-carat="1-2 Carats">1 - 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3-5 Carats">3 - 5 ct</button>
                    <button type="button" class="carat-btn" data-carat="5+ Carats">5+ ct</button>
                  
                  {%- when 'wedding', 'wedding-bands' -%}
                    <button type="button" class="carat-btn" data-carat="Under 0.5 Carats">Under 0.5 ct</button>
                    <button type="button" class="carat-btn" data-carat="0.5-1 Carats">0.5 - 1 ct</button>
                    <button type="button" class="carat-btn" data-carat="1-2 Carats">1 - 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3+ Carats">3+ ct</button>
                  
                  {%- when 'bracelets', 'tennis-bracelets' -%}
                    <button type="button" class="carat-btn" data-carat="Under 3 Carats">Under 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3-5 Carats">3 - 5 ct</button>
                    <button type="button" class="carat-btn" data-carat="5-7 Carats">5 - 7 ct</button>
                    <button type="button" class="carat-btn" data-carat="7-10 Carats">7 - 10 ct</button>
                    <button type="button" class="carat-btn" data-carat="10+ Carats">10+ ct</button>
                  
                  {%- when 'earrings' -%}
                    <button type="button" class="carat-btn" data-carat="Under 0.5 Carats">Under 0.5 ct</button>
                    <button type="button" class="carat-btn" data-carat="0.5-1 Carats">0.5 - 1 ct</button>
                    <button type="button" class="carat-btn" data-carat="1-2 Carats">1 - 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3+ Carats">3+ ct</button>
                  
                  {%- when 'necklaces', 'pendants' -%}
                    <button type="button" class="carat-btn" data-carat="Under 1 Carat">Under 1 ct</button>
                    <button type="button" class="carat-btn" data-carat="1-2 Carats">1 - 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3-5 Carats">3 - 5 ct</button>
                    <button type="button" class="carat-btn" data-carat="5+ Carats">5+ ct</button>
                  
                  {%- else -%}
                    <button type="button" class="carat-btn" data-carat="Under 2 Carats">Under 2 ct</button>
                    <button type="button" class="carat-btn" data-carat="2-3 Carats">2 - 3 ct</button>
                    <button type="button" class="carat-btn" data-carat="3-5 Carats">3 - 5 ct</button>
                    <button type="button" class="carat-btn" data-carat="5-7 Carats">5 - 7 ct</button>
                    <button type="button" class="carat-btn" data-carat="7+ Carats">7+ ct</button>
                {%- endcase -%}
              </div>
            </div>
          </div>
          
          <!-- Diamond Shape Filter - Dynamic per category -->
          <div class="filter-section" data-filter="shape">
            <div class="filter-section__header">
              <span class="filter-section__title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 3h12l4 6-10 13L2 9z"/>
                </svg>
                Diamond Shape
              </span>
              <svg class="filter-section__toggle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="filter-section__content">
              <div class="style-options">
                {%- case collection.handle -%}
                  {%- when 'rings', 'engagement-rings' -%}
                    <label class="style-option"><input type="checkbox" name="shape" value="Round"><span>Round</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Oval"><span>Oval</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Emerald"><span>Emerald</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Cushion"><span>Cushion</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Princess"><span>Princess</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Pear"><span>Pear</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Marquise"><span>Marquise</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Radiant"><span>Radiant</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Asscher"><span>Asscher</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Heart"><span>Heart</span></label>
                  
                  {%- when 'wedding', 'wedding-bands' -%}
                    <label class="style-option"><input type="checkbox" name="shape" value="Round"><span>Round</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Princess"><span>Princess</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Emerald"><span>Emerald</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Oval"><span>Oval</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Baguette"><span>Baguette</span></label>
                  
                  {%- when 'bracelets', 'tennis-bracelets' -%}
                    <label class="style-option"><input type="checkbox" name="shape" value="Round"><span>Round</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Oval"><span>Oval</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Emerald"><span>Emerald</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Cushion"><span>Cushion</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Princess"><span>Princess</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Pear"><span>Pear</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Mixed Shape"><span>Mixed Shape</span></label>
                  
                  {%- when 'earrings' -%}
                    <label class="style-option"><input type="checkbox" name="shape" value="Round"><span>Round</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Oval"><span>Oval</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Emerald"><span>Emerald</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Cushion"><span>Cushion</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Princess"><span>Princess</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Pear"><span>Pear</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Heart"><span>Heart</span></label>
                  
                  {%- when 'necklaces', 'pendants' -%}
                    <label class="style-option"><input type="checkbox" name="shape" value="Round"><span>Round</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Oval"><span>Oval</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Emerald"><span>Emerald</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Cushion"><span>Cushion</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Princess"><span>Princess</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Pear"><span>Pear</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Heart"><span>Heart</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Marquise"><span>Marquise</span></label>
                  
                  {%- else -%}
                    <label class="style-option"><input type="checkbox" name="shape" value="Round"><span>Round</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Oval"><span>Oval</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Emerald"><span>Emerald</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Cushion"><span>Cushion</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Princess"><span>Princess</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Pear"><span>Pear</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Marquise"><span>Marquise</span></label>
                    <label class="style-option"><input type="checkbox" name="shape" value="Radiant"><span>Radiant</span></label>
                {%- endcase -%}
              </div>
            </div>
          </div>
          
          <!-- Jewelry Type Filter - Dynamic based on collection -->
          <div class="filter-section" data-filter="type">
            <div class="filter-section__header">
              <span class="filter-section__title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 3l1.912 5.813h6.124l-4.962 3.587 1.912 5.813L12 14.626l-4.986 3.587 1.912-5.813-4.962-3.587h6.124z"/>
                </svg>
                {%- case collection.handle -%}
                  {%- when 'bracelets', 'tennis-bracelets' -%}
                    Bracelet Style
                  {%- when 'rings', 'engagement-rings' -%}
                    Ring Style
                  {%- when 'wedding', 'wedding-bands' -%}
                    Band Style
                  {%- when 'earrings' -%}
                    Earring Style
                  {%- when 'necklaces', 'pendants' -%}
                    Necklace Style
                  {%- else -%}
                    Jewelry Type
                {%- endcase -%}
              </span>
              <svg class="filter-section__toggle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="filter-section__content">
              <div class="style-options">
                {%- case collection.handle -%}
                  {%- when 'bracelets', 'tennis-bracelets' -%}
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Tennis Bracelet">
                      <span>Tennis Bracelet</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Bangle">
                      <span>Bangle</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Chain Bracelet">
                      <span>Chain Bracelet</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Cuff">
                      <span>Cuff</span>
                    </label>
                  
                  {%- when 'rings', 'engagement-rings' -%}
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Solitaire">
                      <span>Solitaire</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Halo">
                      <span>Halo</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Three Stone">
                      <span>Three Stone</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Hidden Halo">
                      <span>Hidden Halo</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Pave">
                      <span>Pave</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Vintage">
                      <span>Vintage</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Wedding Band">
                      <span>Wedding Band</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Eternity Band">
                      <span>Eternity Band</span>
                    </label>
                  
                  {%- when 'wedding', 'wedding-bands' -%}
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Wedding Band">
                      <span>Wedding Band</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Eternity Band">
                      <span>Eternity Band</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Half Eternity">
                      <span>Half Eternity</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Stackable">
                      <span>Stackable</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Anniversary Band">
                      <span>Anniversary Band</span>
                    </label>
                  
                  {%- when 'earrings' -%}
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Studs">
                      <span>Studs</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Hoops">
                      <span>Hoops</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Drop">
                      <span>Drop</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Huggie">
                      <span>Huggie</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Dangle">
                      <span>Dangle</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Climber">
                      <span>Climber</span>
                    </label>
                  
                  {%- when 'necklaces', 'pendants' -%}
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Pendant">
                      <span>Pendant</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Solitaire Necklace">
                      <span>Solitaire</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Tennis Necklace">
                      <span>Tennis Necklace</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Chain">
                      <span>Chain</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Choker">
                      <span>Choker</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Statement">
                      <span>Statement</span>
                    </label>
                  
                  {%- else -%}
                    <!-- Default: Show all jewelry categories -->
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Tennis Bracelet">
                      <span>Tennis Bracelet</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Engagement Ring">
                      <span>Engagement Ring</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Wedding Band">
                      <span>Wedding Band</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Pendant">
                      <span>Pendant</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Earrings">
                      <span>Earrings</span>
                    </label>
                    <label class="style-option">
                      <input type="checkbox" name="type" value="Necklace">
                      <span>Necklace</span>
                    </label>
                {%- endcase -%}
              </div>
            </div>
          </div>
          
          <!-- Price Range Filter -->
          <div class="filter-section" data-filter="price">
            <div class="filter-section__header">
              <span class="filter-section__title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23"/>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
                Price Range
              </span>
              <svg class="filter-section__toggle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
            <div class="filter-section__content">
              <div class="price-inputs">
                <input type="text" class="price-input" id="minPrice" name="minPrice" placeholder="$0" value="">
                <span class="price-separator">to</span>
                <input type="text" class="price-input" id="maxPrice" name="maxPrice" placeholder="$10,000" value="">
              </div>
            </div>
          </div>
          
          <!-- Shopify Native Filters (if available) -->
          {%- for filter in collection.filters -%}
            {%- unless filter.param_name contains 'price' or filter.param_name contains 'availability' -%}
              <div class="filter-section" data-filter="{{ filter.param_name }}">
                <div class="filter-section__header">
                  <span class="filter-section__title">{{ filter.label }}</span>
                  <svg class="filter-section__toggle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </div>
                <div class="filter-section__content">
                  <div class="style-options">
                    {%- for value in filter.values -%}
                      <label class="style-option {% if value.active %}active{% endif %}">
                        <input 
                          type="checkbox" 
                          name="{{ value.param_name }}" 
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        >
                        <span>{{ value.label }} ({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              </div>
            {%- endunless -%}
          {%- endfor -%}
          
          <button type="submit" class="filter-apply-btn">
            Apply
          </button>
          
          <button type="button" class="filter-clear-btn">
            Reset
          </button>
        </form>
      </aside>

      <!-- Product Results -->
      <section class="products-results">
        <div class="results-header">
          <span class="results-count">Showing <strong>{{ collection.products_count }}</strong> pieces</span>
          <div class="sort-dropdown">
            <label for="sortBy">Sort</label>
            <select id="sortBy" onchange="window.location.href = this.value;">
              {%- for option in collection.sort_options -%}
                <option value="{{ option.url }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        </div>

        {%- if collection.products.size > 0 -%}
          <div class="products-grid" id="productsGrid" style="grid-template-columns: repeat(3, 1fr);">
            {%- for product in collection.products -%}
              {%- assign product_tags_lower = product.tags | join: '|||' | downcase -%}
              {%- assign product_title_lower = product.title | downcase -%}
              <div class="product-card-wrapper"
                data-tags="{{ product_tags_lower }}"
                data-title="{{ product.title | escape }}"
                data-title-lower="{{ product_title_lower }}"
                data-type="{{ product.type | downcase }}"
                data-price="{{ product.price | money_without_currency | remove: ',' }}"
                data-price-cents="{{ product.price }}"
              >
                {% render 'product-card', product: product %}
              </div>
            {%- endfor -%}
          </div>

          <!-- JS-controlled no-results message (hidden by default) -->
          <div class="collection-empty filter-no-results text-center" id="filterNoResults" style="padding: 4rem; display: none;">
            <h3>No pieces match these refinements</h3>
            <p>Adjust your selections, or clear the refinements to see the full collection.</p>
            <button type="button" class="btn btn--primary" id="clearAllFiltersBtn">Reset</button>
          </div>

          {%- if paginate.pages > 1 -%}
            <div class="pagination">
              {{ paginate | default_pagination: next: '→', previous: '←' }}
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="collection-empty text-center" style="padding: 4rem;">
            <h3>No pieces in this collection yet</h3>
            <p class="text-muted">Adjust your refinements, or explore the full atelier.</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Browse the full atelier</a>
          </div>
        {%- endif -%}
      </section>
    </div>
  </div>
</section>

