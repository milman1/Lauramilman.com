        { "@type": "Question", "name": "Is a lab-grown piece as durable as a mined one?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Lab-grown diamonds have identical physical, chemical, and optical properties to mined diamonds. They score a 10 on the Mohs hardness scale." } }
      ]
    }
    </script>

    <div class="sus-cta">
      <h2 class="sus-cta__heading">Heirlooms with provenance</h2>
      <p class="sus-cta__text">Each Laura Milman piece arrives with the documents to prove it. Read more on diamond origin, or explore the collection.</p>
      <div class="sus-cta__links">
        <a href="/pages/why-lab-grown" class="sus-cta__btn sus-cta__btn--outline">On diamond origin &rarr;</a>
        <a href="/collections/engagement-rings" class="sus-cta__btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3h12l4 6-10 13L2 9z"/></svg>
          Explore the collection &rarr;
        </a>
      </div>
    </div>

  </div>
</section>

