<section class="newsletter" data-animate>
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p>{{ section.settings.subheading }}</p>
    {%- endif -%}
    {% form 'customer', class: 'newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label for="NewsletterEmail" class="visually-hidden">{{ 'general.newsletter.placeholder' | t }}</label>
      <input
        id="NewsletterEmail"
        type="email"
        name="contact[email]"
        placeholder="{{ 'general.newsletter.placeholder' | t }}"
        required
        autocomplete="email">
      <button type="submit">{{ 'general.newsletter.submit' | t }}</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Letters from the studio" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join our list" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Quiet dispatches on new pieces, studio visits, and behind-the-scenes work." }
  ],
  "presets": [ { "name": "Newsletter" } ]
}
{% endschema %}
