{%- comment -%}
  Laura Milman — Article (single post in The Journal).
  Layout cloned from PD; palette swapped, schema.org publisher set to LM.
{%- endcomment -%}

<style>
  .article-page { background: #efecec; min-height: 100vh; padding-top: 100px; }
  .article-container { max-width: 780px; margin: 0 auto; padding: 2rem; }
  .article-header { text-align: center; margin-bottom: 2.5rem; }
  .article-meta { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-muted, #7b8382); margin-bottom: 1rem; }
  .article-meta__divider { margin: 0 0.5rem; color: var(--border-light, #e5e2dc); }
  .article-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 400; color: var(--text-dark, #1c1a1a); margin: 0 0 1.25rem; line-height: 1.2; font-style: italic; }
  .article-line { width: 50px; height: 1px; background: var(--accent-gold, #dea882); margin: 0 auto; }
  .article-hero { border-radius: 4px; overflow: hidden; margin-bottom: 2.5rem; }
  .article-hero img { width: 100%; height: auto; display: block; }
  .article-content { font-size: 1.05rem; line-height: 1.85; color: #2a2828; }
  .article-content h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.6rem; font-weight: 500; color: var(--text-dark, #1c1a1a); margin: 2.5rem 0 1rem; }
  .article-content h3 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.3rem; font-weight: 500; color: var(--text-dark, #1c1a1a); margin: 2rem 0 0.75rem; }
  .article-content p { margin: 0 0 1.25rem; }
  .article-content a { color: var(--accent-gold, #dea882); text-decoration: underline; text-underline-offset: 2px; }
  .article-content img { max-width: 100%; height: auto; border-radius: 4px; margin: 1.5rem 0; }
  .article-content ul, .article-content ol { padding-left: 1.5rem; margin: 0 0 1.25rem; }
  .article-content li { margin-bottom: 0.5rem; }
  .article-content blockquote { border-left: 2px solid var(--accent-gold, #dea882); margin: 1.5rem 0; padding: 1rem 1.5rem; font-style: italic; color: var(--text-muted, #7b8382); background: rgba(222,168,130,0.05); border-radius: 0 4px 4px 0; }
  .article-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-light, #e5e2dc); }
  .article-tag { display: inline-block; padding: 4px 14px; border-radius: 20px; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; background: rgba(222,168,130,0.12); color: var(--accent-gold-dark, #c89066); text-decoration: none; transition: background 0.2s ease; }
  .article-tag:hover { background: rgba(222,168,130,0.22); }
  .article-back { display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 2.5rem; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-muted, #7b8382); text-decoration: none; transition: color 0.2s ease; }
  .article-back:hover { color: var(--accent-gold, #dea882); }
  @media (max-width: 768px) { .article-page { padding-top: 80px; } .article-container { padding: 1.25rem; } .article-content { font-size: 0.95rem; } }
</style>

<div class="article-page">
  <div class="article-container">
    <nav class="breadcrumbs" aria-label="Breadcrumb" style="padding: 0 0 1.5rem; padding-top: 0;">
      <ol class="breadcrumbs__list">
        <li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">Home</a></li>
        <li class="breadcrumbs__item"><a href="{{ blog.url }}" class="breadcrumbs__link">{{ blog.title }}</a></li>
        <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">{{ article.title | truncate: 40 }}</li>
      </ol>
    </nav>

    <article>
      <div class="article-header">
        <p class="article-meta">
          {{ article.published_at | date: '%B %d, %Y' }}
          {%- if article.author -%}
            <span class="article-meta__divider">·</span>
            {{ article.author }}
          {%- endif -%}
        </p>
        <h1 class="article-title">{{ article.title }}</h1>
        <div class="article-line"></div>
      </div>

      {%- if article.image -%}
        <div class="article-hero">
          <img
            src="{{ article.image | image_url: width: 1200 }}"
            srcset="{{ article.image | image_url: width: 600 }} 600w,
                    {{ article.image | image_url: width: 900 }} 900w,
                    {{ article.image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 780px) 100vw, 780px"
            alt="{{ article.image.alt | default: article.title | escape }}"
          >
        </div>
      {%- endif -%}

      <div class="article-content">{{ article.content }}</div>

      {%- if article.tags.size > 0 -%}
        <div class="article-tags">
          {%- for tag in article.tags -%}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-tag">{{ tag }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <a href="{{ blog.url }}" class="article-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        Return to {{ blog.title }}
      </a>
    </article>
  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S' }}",
  {%- if article.updated_at -%}
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S' }}",
  {%- endif -%}
  {%- if article.image -%}
  "image": "https:{{ article.image | image_url: width: 1200 }}",
  {%- endif -%}
  "author": { "@type": "Person", "name": {{ article.author | json }} },
  "publisher": { "@type": "Organization", "name": "Laura Milman", "url": "{{ shop.url }}" },
  "description": {{ article.excerpt_or_content | strip_html | truncate: 160 | json }},
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ shop.url }}{{ article.url }}" }
}
</script>

{% schema %}
{ "name": "Article", "settings": [] }
{% endschema %}
