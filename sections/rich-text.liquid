<section class="section {% if section.settings.style == 'dark' %}rich-text--dark{% endif %}">
  <div class="page-width">
    <div class="rich-text" data-animate>
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'eyebrow' -%}
            <span class="eyebrow" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {%- when 'heading' -%}
            <h2 {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
          {%- when 'text' -%}
            <div {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- when 'button' -%}
            <div class="mt-2" {{ block.shopify_attributes }}>
              <a class="btn" href="{{ block.settings.link }}">{{ block.settings.label }}</a>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "light"
    }
  ],
  "blocks": [
    { "type": "eyebrow", "name": "Eyebrow", "settings": [ { "type": "text", "id": "text", "label": "Text", "default": "Manifesto" } ] },
    { "type": "heading", "name": "Heading", "settings": [ { "type": "text", "id": "text", "label": "Heading", "default": "A quieter kind of luxury." } ] },
    { "type": "text", "name": "Text", "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<p>We believe an object earns its place by being used. Our collection is designed to live with you, patinate, and carry the story of how it was worn.</p>" } ] },
    { "type": "button", "name": "Button", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Read the story" },
      { "type": "url", "id": "link", "label": "Link" }
    ] }
  ],
  "presets": [
    {
      "name": "Rich text",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "text" }
      ]
    }
  ]
}
{% endschema %}
