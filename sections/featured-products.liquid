{%- comment -%}
  Laura Milman New York — Featured Products Section
  Product grid from a selected collection with eyebrow/title/description header
{%- endcomment -%}

{%- liquid
  assign limit = section.settings.product_count | default: 8
  assign featured_collection = section.settings.collection
  assign view_all_url = '/collections/all'
  if featured_collection != blank
    assign view_all_url = featured_collection.url
  endif
-%}

<section class="lm-featured" aria-label="{{ section.settings.title | default: 'Featured Products' | escape }}">
  <div class="lm-featured__container">

    <div class="lm-featured__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="lm-featured__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="products-grid">
      {%- if featured_collection != blank and featured_collection.products.size > 0 -%}
        {%- for product in featured_collection.products limit: limit -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- elsif collections.all.products.size > 0 -%}
        {%- for product in collections.all.products limit: limit -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        <p class="lm-featured__empty">Add products to your store to see them here.</p>
      {%- endif -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div class="lm-featured__footer">
        <a href="{{ section.settings.cta_url | default: view_all_url }}" class="view-all-link">
          {{ section.settings.cta_text }} →
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .lm-featured {
    background: var(--warm-white, #FDFBF7);
    padding: 5rem 2rem;
  }

  .lm-featured__container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .lm-featured__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  .lm-featured__desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted, #8B7D6B);
    margin: 1rem 0 0;
  }

  .lm-featured .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .lm-featured__empty {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--text-muted, #8B7D6B);
    padding: 3rem 0;
  }

  .lm-featured__footer {
    text-align: center;
    margin-top: 3rem;
  }

  @media (max-width: 1024px) {
    .lm-featured .products-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .lm-featured {
      padding: 3.5rem 1rem;
    }
    .lm-featured .products-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .lm-featured__header {
      margin-bottom: 2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curated Selection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Pieces"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "View All text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "View All link"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
