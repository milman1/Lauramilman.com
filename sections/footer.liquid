<footer class="site-footer" role="contentinfo">
  <div class="page-width">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <h3>{{ section.settings.heading | default: shop.name }}</h3>
        <p>{{ section.settings.description }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <div>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}</div>
      <div class="site-footer__social">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" aria-label="Instagram" rel="noopener" target="_blank">{% render 'icon-instagram' %}</a>
        {%- endif -%}
        {%- if settings.social_pinterest != blank -%}
          <a href="{{ settings.social_pinterest }}" aria-label="Pinterest" rel="noopener" target="_blank">{% render 'icon-pinterest' %}</a>
        {%- endif -%}
        {%- if settings.social_facebook != blank -%}
          <a href="{{ settings.social_facebook }}" aria-label="Facebook" rel="noopener" target="_blank">{% render 'icon-facebook' %}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Brand heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "Considered pieces, quietly made. Laurel & Gold is a studio of heirloom objects drawn from nature, finished by hand, and built to outlast trend."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright line",
      "default": "All rights reserved."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu" },
        { "type": "menu" },
        { "type": "menu" }
      ]
    }
  ]
}
{% endschema %}
