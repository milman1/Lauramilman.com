</div>

<script>
(function() {
  var stlBackdrop = document.getElementById('stlModal');
  var stlOpen = document.getElementById('stlModalOpen');
  var stlClose = document.getElementById('stlModalClose');

  if (stlBackdrop && stlOpen) {
    stlOpen.addEventListener('click', function() { stlBackdrop.classList.add('stl-modal--open'); document.body.style.overflow = 'hidden'; });
    stlClose && stlClose.addEventListener('click', function() { stlBackdrop.classList.remove('stl-modal--open'); document.body.style.overflow = ''; });
    stlBackdrop.addEventListener('click', function(e) { if (e.target === stlBackdrop) { stlBackdrop.classList.remove('stl-modal--open'); document.body.style.overflow = ''; } });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && stlBackdrop.classList.contains('stl-modal--open')) { stlBackdrop.classList.remove('stl-modal--open'); document.body.style.overflow = ''; } });
  }

  var runway = document.querySelector('.fp__runway');
  if (runway) {
    var leftBtn = document.querySelector('.fp__arrow--left');
    var rightBtn = document.querySelector('.fp__arrow--right');
    var scrollAmt = 280;
    if (leftBtn) leftBtn.addEventListener('click', function() { runway.scrollBy({ left: -scrollAmt, behavior: 'smooth' }); });
    if (rightBtn) rightBtn.addEventListener('click', function() { runway.scrollBy({ left: scrollAmt, behavior: 'smooth' }); });
  }

  document.querySelectorAll('.ring-carousel__track-wrap').forEach(function(wrap) {
    var track = wrap.querySelector('.ring-carousel__track, .rc-track');
    var left = wrap.querySelector('.ring-carousel__arrow--left, .rc-arrow-left');
    var right = wrap.querySelector('.ring-carousel__arrow--right, .rc-arrow-right');
    if (!track) return;
    var amt = 300;
    if (left) left.addEventListener('click', function() { track.scrollBy({ left: -amt, behavior: 'smooth' }); });
    if (right) right.addEventListener('click', function() { track.scrollBy({ left: amt, behavior: 'smooth' }); });
  });

  var isTouch = window.matchMedia('(hover: none) and (pointer: coarse)').matches;
  if (!isTouch) {
    var ytApiReady = false; var ytQueue = [];
    function loadYTApi() { if (document.querySelector('script[src*="youtube.com/iframe_api"]')) return; var tag = document.createElement('script'); tag.src = 'https://www.youtube.com/iframe_api'; document.head.appendChild(tag); }
    window.onYouTubeIframeAPIReady = function() { ytApiReady = true; ytQueue.forEach(function(fn) { fn(); }); ytQueue = []; };
    function initYTPlayer(wrap, ytId) { var div = document.createElement('div'); wrap.appendChild(div); return new YT.Player(div, { videoId: ytId, playerVars: { autoplay: 0, controls: 0, mute: 1, loop: 1, playlist: ytId, modestbranding: 1, showinfo: 0, rel: 0, playsinline: 1 }, events: { onReady: function(e) { wrap._player = e.target; e.target.mute(); } } }); }
    function setupCardHover(card) {
      var nativeVideo = card.querySelector('.spotlight__video, .fp__card-video');
      var ytWrap = card.querySelector('.spotlight__yt-wrap, .fp__card-yt-wrap');
      var cycleImgs = card.querySelectorAll('.spotlight__img--cycle, .fp__cycle-img');
      var cycleTimer = null; var cycleIdx = 0;
      if (nativeVideo) {
        card.addEventListener('mouseenter', function() {
          if (!nativeVideo.src && nativeVideo.dataset.src) { nativeVideo.src = nativeVideo.dataset.src; nativeVideo.load(); }
          nativeVideo.play().then(function() { nativeVideo.classList.add('spotlight__video--playing', 'fp__card-video--playing'); }).catch(function() {});
        });
        card.addEventListener('mouseleave', function() { nativeVideo.pause(); nativeVideo.currentTime = 0; nativeVideo.classList.remove('spotlight__video--playing', 'fp__card-video--playing'); });
        return;
      }
      if (ytWrap) {
        var ytId = ytWrap.dataset.ytId;
        if (!ytId) return;
        loadYTApi();
        var ready = function() { initYTPlayer(ytWrap, ytId); };
        if (ytApiReady) ready(); else ytQueue.push(ready);
        card.addEventListener('mouseenter', function() { if (ytWrap._player && typeof ytWrap._player.playVideo === 'function') { ytWrap._player.playVideo(); ytWrap.classList.add('spotlight__yt-wrap--playing', 'fp__card-yt-wrap--playing'); } });
        card.addEventListener('mouseleave', function() { if (ytWrap._player && typeof ytWrap._player.pauseVideo === 'function') { ytWrap._player.pauseVideo(); } ytWrap.classList.remove('spotlight__yt-wrap--playing', 'fp__card-yt-wrap--playing'); });
        return;
      }
      if (cycleImgs.length > 1) {
        card.addEventListener('mouseenter', function() {
          cycleIdx = 0;
          cycleTimer = setInterval(function() { cycleImgs[cycleIdx].classList.remove('spotlight__img--active', 'fp__cycle-img--active'); cycleIdx = (cycleIdx + 1) % cycleImgs.length; cycleImgs[cycleIdx].classList.add('spotlight__img--active', 'fp__cycle-img--active'); }, 1200);
        });
        card.addEventListener('mouseleave', function() { clearInterval(cycleTimer); cycleImgs.forEach(function(img, i) { img.classList.toggle('spotlight__img--active', i === 0); img.classList.toggle('fp__cycle-img--active', i === 0); }); cycleIdx = 0; });
      }
    }
    document.querySelectorAll('.spotlight__card').forEach(setupCardHover);
    document.querySelectorAll('.fp__card').forEach(setupCardHover);
  }
})();
</script>

{% schema %}
{
  "name": "Our Story",
  "settings": [
    { "type": "header", "content": "Hero Section" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "New York · Three generations" },
    { "type": "text", "id": "hero_title", "label": "Hero title", "default": "Three generations in the atelier" },
    { "type": "text", "id": "hero_subtitle", "label": "Hero subtitle", "default": "The Milman family workshop, in New York since 1962." },
    { "type": "text", "id": "hero_button_text", "label": "Primary button text", "default": "Explore the collection" },
    { "type": "url", "id": "hero_button_link", "label": "Primary button link" },
    { "type": "text", "id": "hero_button_2_text", "label": "Secondary button text", "default": "Read the heritage" },
    { "type": "url", "id": "hero_button_2_link", "label": "Secondary button link" },

