  <!-- Stats -->
  <section class="story-section story-section--stats">
    <div class="story-container">
      <div class="story-stats">
        <div class="story-stat"><svg class="story-stat__icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="15"/><path d="M20 5 L20 20 L30 20"/></svg><span class="story-stat__number">3</span><span class="story-stat__label">Generations at the bench</span></div>
        <div class="story-stat"><svg class="story-stat__icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="15"/><path d="M12 20 L18 26 L28 14"/></svg><span class="story-stat__number">85%</span><span class="story-stat__label">Smaller footprint than mining</span></div>
        <div class="story-stat"><svg class="story-stat__icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 5 L35 15 L35 30 L20 35 L5 30 L5 15 Z"/><path d="M12 18 L18 24 L28 14"/></svg><span class="story-stat__number">IGI / GIA</span><span class="story-stat__label">Independently graded</span></div>
        <div class="story-stat"><svg class="story-stat__icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="8" y="12" width="24" height="20" rx="2"/><path d="M8 18 L20 24 L32 18"/></svg><span class="story-stat__number">NYC</span><span class="story-stat__label">Hand-finished in our atelier</span></div>
