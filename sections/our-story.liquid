{%- comment -%}
  Laura Milman — Heritage page (Milman Heritage).
  Layout cloned from PD; palette swapped to LM heritage tokens; copy
  rewritten for the Milman family workshop voice. Heavy CSS extracted
  to snippets/our-story-styles.liquid.
{%- endcomment -%}

{% render 'our-story-styles' %}


<!-- Floating Background Diamonds -->
<div class="floating-diamonds">
  <svg class="floating-diamond" width="150" height="180" viewBox="0 0 100 120"><path d="M50 5 L75 30 L50 115 L25 30 Z" stroke="#dea882" stroke-width="1" fill="none"/></svg>
  <svg class="floating-diamond" width="100" height="120" viewBox="0 0 100 120"><path d="M50 5 L75 30 L50 115 L25 30 Z" stroke="#dea882" stroke-width="1" fill="none"/></svg>
  <svg class="floating-diamond" width="120" height="144" viewBox="0 0 100 120"><path d="M50 5 L75 30 L50 115 L25 30 Z" stroke="#dea882" stroke-width="1" fill="none"/></svg>
  <svg class="floating-diamond" width="80" height="96" viewBox="0 0 100 120"><path d="M50 5 L75 30 L50 115 L25 30 Z" stroke="#dea882" stroke-width="1" fill="none"/></svg>
  <svg class="floating-diamond" width="200" height="240" viewBox="0 0 100 120"><path d="M50 5 L75 30 L50 115 L25 30 Z" stroke="#dea882" stroke-width="0.5" fill="none"/></svg>
</div>

<div class="story-page">
  <!-- Hero -->
  <section class="story-hero">
    <div class="story-hero__bg"></div>
    <svg class="story-hero__diamond" viewBox="0 0 100 120" fill="none">
      <path d="M50 5 L80 35 L50 115 L20 35 Z" stroke="#dea882" stroke-width="0.5" fill="none"/>
      <path d="M20 35 L80 35" stroke="#dea882" stroke-width="0.3"/>
      <path d="M50 5 L35 35 M50 5 L65 35" stroke="#dea882" stroke-width="0.3"/>
      <circle cx="50" cy="50" r="25" stroke="#dea882" stroke-width="0.3" fill="none"/>
    </svg>
    <div class="story-hero__line-left"></div>
    <div class="story-hero__line-right"></div>
    <div class="story-hero__content">
      <p class="story-hero__eyebrow">{{ section.settings.eyebrow | default: 'New York · Three generations' }}</p>
      <h1 class="story-hero__title">{{ section.settings.hero_title | default: 'Three generations in the atelier' }}</h1>
      <p class="story-hero__subtitle">{{ section.settings.hero_subtitle | default: 'The Milman family workshop, in New York since 1962. Heirloom pieces, hand-finished by master setters.' }}</p>
      <div class="story-hero__buttons" style="display: flex; gap: 1rem; justify-content: center; margin-top: 2.5rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 1s ease forwards 0.9s;">
        {%- if section.settings.hero_button_text != blank -%}
          <a href="{{ section.settings.hero_button_link | default: '/collections/rings' }}" class="btn btn--gold btn--lg">{{ section.settings.hero_button_text }}</a>
        {%- else -%}
          <a href="/collections/rings" class="btn btn--gold btn--lg">Explore the collection</a>
        {%- endif -%}
        {%- if section.settings.hero_button_2_text != blank -%}
          <a href="{{ section.settings.hero_button_2_link | default: '#story-content' }}" class="btn btn--secondary btn--lg">{{ section.settings.hero_button_2_text }}</a>
        {%- else -%}
          <a href="#story-content" class="btn btn--secondary btn--lg">Read the heritage</a>
        {%- endif -%}
      </div>
    </div>
    <div class="hero-trust-badges" id="story-content">
      <div class="hero-trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg><span>Insured delivery</span></div>
      <span class="hero-trust-badge__sep">|</span>
      <div class="hero-trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg><span>30-day returns</span></div>
      <span class="hero-trust-badge__sep">|</span>
      <div class="hero-trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg><span>Hand-finished in NY</span></div>
      <span class="hero-trust-badge__sep">|</span>
      <div class="hero-trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2z"/></svg><span>Lifetime warranty</span></div>
    </div>
  </section>

  <!-- Collection Spotlight — 5 Category Cards -->
  {%- assign spot_collections = 'engagement-rings,earrings,bracelets,necklaces,pendants' | split: ',' -%}
  <section class="spotlight">
    <div class="spotlight__row">
      {%- for col_handle in spot_collections -%}
        {%- assign spot_col = collections[col_handle] -%}
        {%- if spot_col != blank -%}
          <a href="{{ spot_col.url }}" class="spotlight__card">
            <div class="spotlight__media">
              {%- if spot_col.image != blank -%}
                <img class="spotlight__img" src="{{ spot_col.image | image_url: width: 600 }}" srcset="{{ spot_col.image | image_url: width: 300 }} 300w, {{ spot_col.image | image_url: width: 450 }} 450w, {{ spot_col.image | image_url: width: 600 }} 600w" sizes="(max-width: 768px) 50vw, 25vw" alt="{{ spot_col.title | escape }}" loading="lazy" decoding="async">
              {%- elsif spot_col.products.first.featured_image != blank -%}
                <img class="spotlight__img" src="{{ spot_col.products.first.featured_image | image_url: width: 600 }}" srcset="{{ spot_col.products.first.featured_image | image_url: width: 300 }} 300w, {{ spot_col.products.first.featured_image | image_url: width: 450 }} 450w, {{ spot_col.products.first.featured_image | image_url: width: 600 }} 600w" sizes="(max-width: 768px) 50vw, 25vw" alt="{{ spot_col.title | escape }}" loading="lazy" decoding="async">
              {%- endif -%}
            </div>
            <div class="spotlight__info"><h3 class="spotlight__name">{{ spot_col.title }}</h3><svg class="spotlight__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>

  <!-- Featured Products — Editorial -->
  {%- assign grid_collection = section.settings.grid_collection -%}
  {%- if grid_collection == blank or grid_collection.products.size == 0 -%}
    {%- assign grid_collection = collections['all'] -%}
  {%- endif -%}
  {%- assign grid_limit = section.settings.grid_count | default: 8 -%}
  <section class="fp">
    <div class="fp__header">
      <span class="fp__eyebrow">{{ section.settings.grid_eyebrow | default: 'From the atelier' }}</span>
      <h2 class="fp__title">{{ section.settings.grid_heading | default: 'Pieces of note' }}</h2>
      <div class="fp__title-line"></div>
      <p class="fp__subtitle">{{ section.settings.grid_subtitle | default: 'Recent work from the atelier — hand-finished in New York.' }}</p>
    </div>

    {%- assign products_arr = grid_collection.products -%}
    {%- if products_arr.size > 0 -%}
      <div class="fp__bento">
        {%- assign hero_product = products_arr[0] -%}
        {%- assign hp_video_url = nil -%}
        {%- assign hp_video_type = nil -%}
        {%- for media in hero_product.media -%}
          {%- if hp_video_url == nil -%}
            {%- if media.media_type == 'video' -%}
              {%- for source in media.sources -%}{%- if hp_video_url == nil -%}{%- assign hp_video_url = source.url -%}{%- assign hp_video_type = 'native' -%}{%- endif -%}{%- endfor -%}
            {%- elsif media.media_type == 'external_video' and media.host == 'youtube' -%}
              {%- assign hp_video_url = media.external_id -%}{%- assign hp_video_type = 'youtube' -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        <a href="{{ hero_product.url }}" class="fp__card{% if hp_video_url %} fp__card--has-video{% endif %}"{%- if hp_video_type == 'youtube' %} data-yt-id="{{ hp_video_url }}"{% endif -%}{%- if hp_video_url == nil and hero_product.images.size > 1 %} data-img-cycle="true"{% endif -%}>
          <div class="fp__card-media">
            {%- if hp_video_type == 'native' -%}<video class="fp__card-video" muted loop playsinline preload="none" data-src="{{ hp_video_url }}"></video>
            {%- elsif hp_video_type == 'youtube' -%}<div class="fp__card-yt-wrap" data-yt-id="{{ hp_video_url }}"></div>{%- endif -%}
            {%- if hp_video_url == nil and hero_product.images.size > 1 -%}
              {%- for img in hero_product.images -%}<img class="fp__cycle-img{% if forloop.first %} fp__cycle-img--active{% endif %}" src="{{ img | image_url: width: 600 }}" alt="{{ img.alt | default: hero_product.title | escape }}" loading="lazy" decoding="async">{%- endfor -%}
            {%- elsif hero_product.featured_image != blank -%}
              <img src="{{ hero_product.featured_image | image_url: width: 600 }}" alt="{{ hero_product.featured_image.alt | default: hero_product.title | escape }}" loading="lazy" decoding="async">
            {%- endif -%}
          </div>
          <div class="fp__card-info"><h3 class="fp__card-name">{{ hero_product.title }}</h3><p class="fp__card-price">{{ hero_product.price | money }}</p></div>
        </a>
        {%- for i in (1..2) -%}
          {%- assign side_product = products_arr[i] -%}
          {%- if side_product and side_product.featured_image != blank -%}
            {%- assign sp_video_url = nil -%}{%- assign sp_video_type = nil -%}
            {%- for media in side_product.media -%}{%- if sp_video_url == nil -%}{%- if media.media_type == 'video' -%}{%- for source in media.sources -%}{%- if sp_video_url == nil -%}{%- assign sp_video_url = source.url -%}{%- assign sp_video_type = 'native' -%}{%- endif -%}{%- endfor -%}{%- elsif media.media_type == 'external_video' and media.host == 'youtube' -%}{%- assign sp_video_url = media.external_id -%}{%- assign sp_video_type = 'youtube' -%}{%- endif -%}{%- endif -%}{%- endfor -%}
            <a href="{{ side_product.url }}" class="fp__card{% if sp_video_url %} fp__card--has-video{% endif %}"{%- if sp_video_type == 'youtube' %} data-yt-id="{{ sp_video_url }}"{% endif -%}{%- if sp_video_url == nil and side_product.images.size > 1 %} data-img-cycle="true"{% endif -%}>
              <div class="fp__card-media">
                {%- if sp_video_type == 'native' -%}<video class="fp__card-video" muted loop playsinline preload="none" data-src="{{ sp_video_url }}"></video>
                {%- elsif sp_video_type == 'youtube' -%}<div class="fp__card-yt-wrap" data-yt-id="{{ sp_video_url }}"></div>{%- endif -%}
                {%- if sp_video_url == nil and side_product.images.size > 1 -%}
                  {%- for img in side_product.images -%}<img class="fp__cycle-img{% if forloop.first %} fp__cycle-img--active{% endif %}" src="{{ img | image_url: width: 600 }}" alt="{{ img.alt | default: side_product.title | escape }}" loading="lazy" decoding="async">{%- endfor -%}
                {%- elsif side_product.featured_image != blank -%}
                  <img src="{{ side_product.featured_image | image_url: width: 600 }}" alt="{{ side_product.featured_image.alt | default: side_product.title | escape }}" loading="lazy" decoding="async">
                {%- endif -%}
              </div>
              <div class="fp__card-info"><h3 class="fp__card-name">{{ side_product.title }}</h3><p class="fp__card-price">{{ side_product.price | money }}</p></div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="fp__footer"><a href="/collections" class="fp__view-all">Explore the collection<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></a></div>
  </section>

  <!-- Shop the Look — Bracelets -->
  {%- assign stl_collection = collections['bracelets'] -%}
  {%- if stl_collection == blank -%}{%- assign stl_collection = collections['tennis-bracelets'] -%}{%- endif -%}
  {%- if stl_collection and stl_collection.products.size >= 3 -%}
    <section class="stl">
      <div class="stl__header"><span class="stl__eyebrow">Shop the Look</span><h2 class="stl__heading">Stack &amp; layer</h2><div class="stl__line"></div></div>
      <div class="stl__grid">
        <div class="stl__lifestyle">
          {%- if stl_collection.image != blank -%}
            <img src="{{ stl_collection.image | image_url: width: 900 }}" srcset="{{ stl_collection.image | image_url: width: 500 }} 500w, {{ stl_collection.image | image_url: width: 700 }} 700w, {{ stl_collection.image | image_url: width: 900 }} 900w" sizes="(max-width: 768px) 100vw, 55vw" alt="{{ stl_collection.title | escape }} lifestyle" loading="lazy" decoding="async">
          {%- elsif stl_collection.products.first.featured_image != blank -%}
            <img src="{{ stl_collection.products.first.featured_image | image_url: width: 900 }}" alt="{{ stl_collection.title | escape }}" loading="lazy" decoding="async">
          {%- endif -%}
          <div class="stl__lifestyle-overlay"><p class="stl__lifestyle-label">{{ stl_collection.title }}</p><p class="stl__lifestyle-sub">{{ stl_collection.products_count }} pieces · From the atelier</p></div>
        </div>
        <div class="stl__products">
          {%- assign stl_count = 0 -%}
          {%- for product in stl_collection.products -%}
            {%- if stl_count >= 4 -%}{%- break -%}{%- endif -%}
            {%- if product.featured_image != blank -%}{%- assign stl_count = stl_count | plus: 1 -%}
              <a href="{{ product.url }}" class="stl__product"><div class="stl__product-img-wrap"><img src="{{ product.featured_image | image_url: width: 250 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" decoding="async"></div><div class="stl__product-details"><h3 class="stl__product-name">{{ product.title }}</h3><p class="stl__product-price">{{ product.price | money }}</p><span class="stl__product-cta">View piece</span></div></a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      <div class="stl__footer" style="display: flex; gap: 1rem; justify-content: center; align-items: center; flex-wrap: wrap;">
        <button class="stl__modal-trigger" id="stlModalOpen" aria-label="Open lookbook"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="3" x2="9" y2="21"/></svg>View full lookbook</button>
        <a href="{{ stl_collection.url }}" class="stl__view-all">View all {{ stl_collection.title | downcase }}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></a>
      </div>
    </section>

    <div class="stl-modal-backdrop" id="stlModal">
      <div class="stl-modal" role="dialog" aria-label="Shop the Look">
        <button class="stl-modal__close" id="stlModalClose" aria-label="Close lookbook"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        <div class="stl-modal__image-side">
          {%- if stl_collection.image != blank -%}<img src="{{ stl_collection.image | image_url: width: 1000 }}" alt="{{ stl_collection.title | escape }} lookbook" loading="lazy">
          {%- elsif stl_collection.products.first.featured_image != blank -%}<img src="{{ stl_collection.products.first.featured_image | image_url: width: 1000 }}" alt="{{ stl_collection.title | escape }}" loading="lazy">{%- endif -%}
          <div class="stl-modal__image-overlay"><p class="stl-modal__image-title">{{ stl_collection.title }}</p><p class="stl-modal__image-sub">{{ stl_collection.products_count }} curated pieces</p></div>
        </div>
        <div class="stl-modal__product-side">
          <div class="stl-modal__product-header"><h3 class="stl-modal__product-heading">Shop these pieces</h3><p class="stl-modal__product-count">{{ stl_collection.products_count }} pieces in this collection</p></div>
          <div class="stl-modal__product-list">
            {%- for product in stl_collection.products limit: 10 -%}{%- if product.featured_image != blank -%}
              <a href="{{ product.url }}" class="stl-modal__item"><div class="stl-modal__item-img"><img src="{{ product.featured_image | image_url: width: 220 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy"></div><div class="stl-modal__item-info"><h4 class="stl-modal__item-name">{{ product.title }}</h4><p class="stl-modal__item-price">{{ product.price | money }}</p><span class="stl-modal__item-cta">View piece →</span></div></a>
            {%- endif -%}{%- endfor -%}
          </div>
          <div class="stl-modal__view-all"><a href="{{ stl_collection.url }}">View full collection<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></a></div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- More from the atelier -->
  {%- if products_arr.size > 3 -%}
    <section class="ring-carousel">
      <div class="ring-carousel__header"><span class="ring-carousel__eyebrow">Keep browsing</span><h2 class="ring-carousel__title">More from the atelier</h2><div class="ring-carousel__line"></div></div>
      <div class="ring-carousel__track-wrap">
        <button class="ring-carousel__arrow ring-carousel__arrow--left rc-arrow-left" aria-label="Scroll left"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg></button>
        <button class="ring-carousel__arrow ring-carousel__arrow--right rc-arrow-right" aria-label="Scroll right"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></button>
        <div class="ring-carousel__track rc-track">
          {%- for product in products_arr offset: 3 limit: grid_limit -%}{%- if product.featured_image != blank -%}
            <a href="{{ product.url }}" class="ring-carousel__card"><div class="ring-carousel__img-wrap"><img class="ring-carousel__img" src="{{ product.featured_image | image_url: width: 500 }}" srcset="{{ product.featured_image | image_url: width: 280 }} 280w, {{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 500 }} 500w" sizes="(max-width: 768px) 200px, 280px" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" decoding="async">{%- if product.compare_at_price > product.price -%}<span class="ring-carousel__badge">Sale</span>{%- endif -%}</div><div class="ring-carousel__body"><h3 class="ring-carousel__name">{{ product.title }}</h3><p class="ring-carousel__price">{{ product.price | money }}</p><span class="ring-carousel__cta-btn">View piece</span></div></a>
          {%- endif -%}{%- endfor -%}
        </div>
      </div>
      <div class="ring-carousel__footer"><a href="/collections" class="ring-carousel__view-all">Explore the collection<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></a></div>
    </section>
  {%- endif -%}

  <!-- Engagement Rings -->
  {%- assign ring_collection = collections['engagement-rings'] -%}
  {%- if ring_collection == blank -%}{%- assign ring_collection = collections['rings'] -%}{%- endif -%}
  {%- if ring_collection and ring_collection.products.size > 0 -%}
    <section class="ring-carousel">
      <div class="ring-carousel__header"><span class="ring-carousel__eyebrow">For the proposal</span><h2 class="ring-carousel__title">Engagement rings</h2><div class="ring-carousel__line"></div></div>
      <div class="ring-carousel__track-wrap">
        <button class="ring-carousel__arrow ring-carousel__arrow--left" aria-label="Scroll left"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg></button>
        <button class="ring-carousel__arrow ring-carousel__arrow--right" aria-label="Scroll right"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></button>
        <div class="ring-carousel__track">
          {%- for product in ring_collection.products limit: 15 -%}{%- if product.featured_image != blank -%}
            <a href="{{ product.url }}" class="ring-carousel__card"><div class="ring-carousel__img-wrap"><img class="ring-carousel__img" src="{{ product.featured_image | image_url: width: 500 }}" srcset="{{ product.featured_image | image_url: width: 280 }} 280w, {{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 500 }} 500w" sizes="(max-width: 768px) 200px, 280px" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" decoding="async">{%- if product.compare_at_price > product.price -%}<span class="ring-carousel__badge">Sale</span>{%- endif -%}</div><div class="ring-carousel__body"><h3 class="ring-carousel__name">{{ product.title }}</h3><p class="ring-carousel__price">{{ product.price | money }}</p><span class="ring-carousel__cta-btn">View ring</span></div></a>
          {%- endif -%}{%- endfor -%}
        </div>
      </div>
      <div class="ring-carousel__footer"><a href="{{ ring_collection.url }}" class="ring-carousel__view-all">View all engagement rings<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></a></div>
    </section>
  {%- endif -%}

  <!-- The Revelation (light section) -->
  <section class="story-section story-section--centered story-section--light">
    <div class="story-container story-container--narrow">
      <span class="story-label">From the house</span>
      <h2 class="story-heading story-heading--large">{{ section.settings.revelation_title | default: 'On choosing the stone honestly' }}</h2>
      <div class="story-text story-text--centered">
        {% if section.settings.revelation_text != blank %}{{ section.settings.revelation_text }}{% else %}<p>A lab-grown diamond is the same carbon crystal as a mined one — graded by the same authorities, set by the same hands, and honest about where it came from. The atelier sets them by choice.</p>{% endif %}
      </div>
      <div style="text-align: center; margin-top: 1.5rem;">
        <a href="{{ section.settings.revelation_button_link | default: '/collections/diamonds' }}" class="btn btn--outline btn--dark">{{ section.settings.revelation_button_text | default: 'Browse the diamond selection' }}</a>
      </div>
    </div>
  </section>

  <!-- Necklaces & Pendants -->
  {%- assign necklace_collection = collections['necklaces'] -%}
  {%- if necklace_collection == blank -%}{%- assign necklace_collection = collections['necklaces-pendants'] -%}{%- endif -%}
  {%- if necklace_collection == blank -%}{%- assign necklace_collection = collections['pendants'] -%}{%- endif -%}
  {%- if necklace_collection and necklace_collection.products.size > 0 -%}
    <section class="spotlight">
