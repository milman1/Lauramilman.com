{%- comment -%}
  Laura Milman — Blog index ("The Journal").
  Cream-on-dark cards cloned from PD; palette swapped to LM tokens.
{%- endcomment -%}

<style>
  .blog-page { background: #efecec; min-height: 100vh; padding-top: 100px; }
  .blog-container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
  .blog-header { text-align: center; margin-bottom: 3rem; }
  .blog-header__eyebrow { display: block; font-size: 0.7rem; letter-spacing: 0.32em; text-transform: uppercase; color: var(--accent-gold, #dea882); margin-bottom: 0.5rem; font-weight: 600; }
  .blog-header__title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; color: var(--text-dark, #1c1a1a); margin: 0 0 0.75rem; font-style: italic; }
  .blog-header__line { width: 50px; height: 1px; background: var(--accent-gold, #dea882); margin: 0 auto; }

  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .blog-card { background: #fff; border-radius: 4px; overflow: hidden; text-decoration: none; color: inherit; box-shadow: 0 2px 12px rgba(0,0,0,0.04); transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .blog-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.08); }
  .blog-card__image { aspect-ratio: 16/10; overflow: hidden; }
  .blog-card__image img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease; }
  .blog-card:hover .blog-card__image img { transform: scale(1.05); }
  .blog-card__body { padding: 1.5rem; }
  .blog-card__date { font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-muted, #7b8382); margin-bottom: 0.5rem; }
  .blog-card__title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; font-weight: 500; color: var(--text-dark, #1c1a1a); margin: 0 0 0.75rem; line-height: 1.3; }
  .blog-card__excerpt { font-size: 0.85rem; color: var(--text-muted, #7b8382); line-height: 1.65; margin: 0 0 1rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .blog-card__cta { font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent-gold, #dea882); font-weight: 600; transition: opacity 0.3s ease; }
  .blog-card:hover .blog-card__cta { opacity: 0.78; }

  .blog-empty { text-align: center; padding: 4rem 2rem; color: var(--text-muted, #7b8382); font-size: 1.05rem; line-height: 1.7; }

  .blog-pagination { display: flex; justify-content: center; gap: 0.5rem; margin-top: 3rem; }
  .blog-pagination a, .blog-pagination span { display: inline-flex; align-items: center; justify-content: center; min-width: 40px; height: 40px; padding: 0 12px; border-radius: 2px; font-size: 0.85rem; text-decoration: none; color: var(--text-dark, #1c1a1a); border: 1px solid var(--border-light, #e5e2dc); transition: all 0.2s ease; }
  .blog-pagination a:hover { border-color: var(--accent-gold, #dea882); color: var(--accent-gold, #dea882); }
  .blog-pagination .current { background: var(--accent-gold, #dea882); color: #1c1a1a; border-color: var(--accent-gold, #dea882); }

  @media (max-width: 768px) { .blog-page { padding-top: 80px; } .blog-container { padding: 1.25rem; } .blog-grid { grid-template-columns: 1fr; gap: 1.25rem; } }
  @media (min-width: 769px) and (max-width: 1024px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<div class="blog-page">
  <div class="blog-container">
    <nav class="breadcrumbs" aria-label="Breadcrumb" style="padding: 0 0 1.5rem; padding-top: 0;">
      <ol class="breadcrumbs__list">
        <li class="breadcrumbs__item"><a href="/" class="breadcrumbs__link">Home</a></li>
        <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">{{ blog.title }}</li>
      </ol>
    </nav>

    <div class="blog-header">
      <span class="blog-header__eyebrow">The Journal</span>
      <h1 class="blog-header__title">{{ blog.title }}</h1>
      <div class="blog-header__line"></div>
    </div>

    {%- if blog.articles.size > 0 -%}
      <div class="blog-grid">
        {%- paginate blog.articles by 12 -%}
          {%- for article in blog.articles -%}
            <a href="{{ article.url }}" class="blog-card">
              {%- if article.image -%}
                <div class="blog-card__image">
                  <img
                    src="{{ article.image | image_url: width: 600 }}"
                    srcset="{{ article.image | image_url: width: 400 }} 400w,
                            {{ article.image | image_url: width: 600 }} 600w"
                    sizes="(max-width: 768px) 100vw, 33vw"
                    alt="{{ article.image.alt | default: article.title | escape }}"
                    loading="lazy"
                  >
                </div>
              {%- endif -%}
              <div class="blog-card__body">
                <p class="blog-card__date">{{ article.published_at | date: '%B %d, %Y' }}</p>
                <h2 class="blog-card__title">{{ article.title }}</h2>
                <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 160 }}</p>
                <span class="blog-card__cta">Read →</span>
              </div>
            </a>
          {%- endfor -%}

          {%- if paginate.pages > 1 -%}
            <div class="blog-pagination" style="grid-column: 1 / -1;">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}">← Prev</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}
                  <span class="current">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}">Next →</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    {%- else -%}
      <div class="blog-empty">
        <p>Stories from the atelier are forthcoming. The Journal will hold notes on heritage, gifting, and pieces from the archive.</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{ "name": "Blog Posts", "settings": [] }
{% endschema %}
