{% comment %}
  Chat widget snippet.
  Include in theme.liquid before </body>: {% render 'chat-widget' %}
{% endcomment %}

<div class="chat-panel" id="chat-panel" aria-label="Live chat" role="dialog" aria-hidden="true">
  <div class="chat-panel__header">
    <span class="chat-panel__header-title">{{ shop.name }}</span>
    <button class="chat-panel__close" aria-label="Close chat">&times;</button>
  </div>
  <div class="chat-panel__body" id="chat-body">
    <div class="chat-msg chat-msg--bot">Welcome to {{ shop.name }}. How can I assist you today?</div>
  </div>
  <div class="chat-panel__input-row">
    <label for="chat-input" class="visually-hidden">Message</label>
    <input
      id="chat-input"
      class="chat-input"
      type="text"
      placeholder="Type a message..."
      autocomplete="off"
    >
    <button class="chat-send-btn" aria-label="Send message">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
      </svg>
    </button>
  </div>
</div>

<button class="chat-trigger" id="chat-trigger" aria-label="Open chat" aria-controls="chat-panel" aria-expanded="false">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
  </svg>
</button>

<style>
  .chat-trigger {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-espresso, #1E1109);
    color: var(--color-gold, #C9A050);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s, background 0.3s;
    z-index: 9998;
  }
  .chat-trigger:hover {
    transform: scale(1.05);
    background: var(--color-text-dark, #2C1810);
  }

  .chat-panel {
    position: fixed;
    bottom: 96px;
    right: 24px;
    width: 360px;
    max-height: 480px;
    background: var(--color-warm-white, #FDFAF6);
    border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12);
    display: flex;
    flex-direction: column;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(16px);
    transition: opacity 0.3s, transform 0.3s, visibility 0.3s;
  }
  .chat-panel.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .chat-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    background: var(--color-espresso, #1E1109);
    border-radius: 12px 12px 0 0;
    color: var(--color-gold, #C9A050);
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
  }
  .chat-panel__close {
    background: none;
    border: none;
    color: var(--color-gold, #C9A050);
    font-size: 22px;
    cursor: pointer;
    line-height: 1;
  }

  .chat-panel__body {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    min-height: 200px;
    max-height: 300px;
  }

  .chat-msg {
    padding: 10px 14px;
    border-radius: 12px;
    margin-bottom: 12px;
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    line-height: 1.5;
    max-width: 85%;
  }
  .chat-msg--bot {
    background: var(--color-cream, #FAF6F0);
    color: var(--color-text-dark, #2C1810);
    border-bottom-left-radius: 4px;
  }
  .chat-msg--user {
    background: var(--color-gold, #C9A050);
    color: var(--color-warm-white, #FDFAF6);
    margin-left: auto;
    border-bottom-right-radius: 4px;
  }

  .chat-panel__input-row {
    display: flex;
    padding: 12px 16px;
    border-top: 1px solid var(--color-rule, #DDD5C5);
    gap: 8px;
  }
  .chat-input {
    flex: 1;
    border: 1px solid var(--color-rule, #DDD5C5);
    border-radius: 8px;
    padding: 10px 14px;
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    background: var(--color-warm-white, #FDFAF6);
    color: var(--color-text-dark, #2C1810);
    outline: none;
    transition: border-color 0.2s;
  }
  .chat-input:focus {
    border-color: var(--color-gold, #C9A050);
  }
  .chat-input::placeholder {
    color: var(--color-text-muted, #8A8070);
  }
  .chat-send-btn {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    border: none;
    background: var(--color-gold, #C9A050);
    color: var(--color-warm-white, #FDFAF6);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .chat-send-btn:hover {
    background: var(--color-gold-light, #E2C27A);
  }

  @media (max-width: 480px) {
    .chat-panel {
      width: calc(100vw - 32px);
      right: 16px;
      bottom: 88px;
    }
  }
</style>
