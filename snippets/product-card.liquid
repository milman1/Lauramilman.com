{% comment %}
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

<a href="{{ product.url }}" class="product-card" aria-label="{{ product.title | escape }}">
  <div class="product-card__image-box">
    {%- if product.tags contains 'new' or product.tags contains 'new-arrival' -%}
      <div class="product-card__tag">New</div>
    {%- elsif product.tags contains 'bestseller' -%}
      <div class="product-card__tag">Bestseller</div>
    {%- elsif product.tags contains 'limited' -%}
      <div class="product-card__tag">Limited</div>
    {%- elsif product.compare_at_price > product.price -%}
      <div class="product-card__tag">Sale</div>
    {%- endif -%}

    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="{{ product.featured_image.width }}"
        height="{{ product.featured_image.height }}"
        loading="lazy"
      >
    {%- else -%}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:'Jost',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(193,167,132,0.2);background:repeating-linear-gradient(30deg,transparent,transparent 8px,rgba(193,167,132,0.025) 8px,rgba(193,167,132,0.025) 9px);">
        Product Image
      </div>
    {%- endif -%}

    <div class="product-card__quick-view" aria-hidden="true">
      {{ 'products.general.quick_view' | t }}
    </div>
  </div>

  <div class="product-card__info">
    <h3 class="product-card__name">{{ product.title }}</h3>
    <div class="product-card__price">
      {{ product.price | money }}
      {%- if product.compare_at_price > product.price -%}
        <s>{{ product.compare_at_price | money }}</s>
      {%- endif -%}
    </div>
  </div>
</a>
