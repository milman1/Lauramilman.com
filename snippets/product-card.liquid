{%- comment -%}
  Laura Milman — Product Card Snippet (copied from PD product-card)
{%- endcomment -%}

{%- comment -%} Find the first video in product media {%- endcomment -%}
{%- assign card_video_url = nil -%}
{%- assign card_video_type = nil -%}
{%- for media in product.media -%}
  {%- if card_video_url == nil -%}
    {%- if media.media_type == 'video' -%}
      {%- for source in media.sources -%}
        {%- if card_video_url == nil -%}
          {%- assign card_video_url = source.url -%}
          {%- assign card_video_type = source.mime_type -%}
        {%- endif -%}
      {%- endfor -%}
    {%- elsif media.media_type == 'external_video' and media.host == 'youtube' -%}
      {%- assign card_video_url = media.external_id -%}
      {%- assign card_video_type = 'youtube' -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

<article class="product-card{% if card_video_url %} product-card--has-video{% endif %}">
  <a href="{{ product.url }}" class="product-card__link">
    <div class="product-card__image-wrapper">
      {%- if product.featured_image != blank -%}
        <img 
          class="product-card__image"
          src="{{ product.featured_image | image_url: width: 400 }}"
          srcset="{{ product.featured_image | image_url: width: 200 }} 200w,
                  {{ product.featured_image | image_url: width: 300 }} 300w,
                  {{ product.featured_image | image_url: width: 400 }} 400w,
                  {{ product.featured_image | image_url: width: 600 }} 600w"
          sizes="(max-width: 480px) 45vw, (max-width: 768px) 45vw, (max-width: 1200px) 30vw, 25vw"
          alt="{{ product.featured_image.alt | escape }}"
          loading="lazy"
          decoding="async"
          width="400"
          height="400"
        >

        {%- if card_video_url and card_video_type != 'youtube' -%}
          <video 
            class="product-card__video"
            muted
            loop
            playsinline
            preload="none"
            data-src="{{ card_video_url }}"
          >
          </video>
        {%- endif -%}

        {%- if card_video_url == nil and product.images[1] != blank -%}
          <img 
            class="product-card__image product-card__image--hover"
            src="{{ product.images[1] | image_url: width: 400 }}"
            srcset="{{ product.images[1] | image_url: width: 200 }} 200w,
                    {{ product.images[1] | image_url: width: 300 }} 300w,
                    {{ product.images[1] | image_url: width: 400 }} 400w,
                    {{ product.images[1] | image_url: width: 600 }} 600w"
            sizes="(max-width: 480px) 45vw, (max-width: 768px) 45vw, (max-width: 1200px) 30vw, 25vw"
            alt="{{ product.images[1].alt | escape }}"
            loading="lazy"
            decoding="async"
            width="400"
            height="400"
          >
        {%- endif -%}
      {%- else -%}
        <div class="product-card__image" style="background: linear-gradient(135deg, #efecec 0%, #c1bcae 100%); display: flex; align-items: center; justify-content: center;">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
      
      <div class="product-card__actions">
        <button class="product-card__action-btn" aria-label="Quick view" data-product-url="{{ product.url }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </button>
        <button class="product-card__action-btn wishlist-btn" aria-label="Add to wishlist" data-product-id="{{ product.id }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>
        {%- if product.available -%}
          <button 
            class="product-card__action-btn add-to-cart-btn" 
            aria-label="Add to cart"
            data-variant-id="{{ product.first_available_variant.id }}"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
              <path d="M3 6h18"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </button>
        {%- endif -%}
      </div>
      
      {%- if product.available == false -%}
        <span class="product-card__badge product-card__badge--sold-out">Sold Out</span>
      {%- elsif product.compare_at_price > product.price -%}
        <span class="product-card__badge product-card__badge--sale">Sale</span>
      {%- endif -%}
    </div>
  </a>
  
  <div class="product-card__content">
    <h4 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h4>
    <p class="product-card__price">
      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__price-old">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
      {{ product.price | money }}
    </p>
    {%- if product.metafields.custom.carat_weight != blank -%}
      <p class="product-card__meta">{{ product.metafields.custom.carat_weight }}ct</p>
    {%- endif -%}
  </div>
</article>
