{%- comment -%}
  Laura Milman — Main Collection styles (extracted to snippet for size)
{%- endcomment -%}
<style>
  /* Ensure collection section is below the fixed header */
  .collection-section {
    padding-top: 120px;
  }
  
  .collection-header {
    padding-top: 2rem;
  }
  
  .jewelry-filters {
    background: var(--bg-white, #fff);
    border-radius: 4px;
    padding: 1.5rem;
  }
  
  .jewelry-filters h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--primary-navy, #1c1a1a);
    border-bottom: 1px solid var(--border-light, #e5e7eb);
    padding-bottom: 1rem;
  }
  
  .filter-section {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-light, #e5e7eb);
  }
  
  .filter-section:last-of-type {
    border-bottom: none;
    margin-bottom: 0;
  }
  
  .filter-section__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    padding: 0.5rem 0;
  }
  
  .filter-section__title {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #1a1a1a;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .filter-section__title svg {
    width: 16px;
    height: 16px;
    color: var(--accent-gold, #dea882);
  }
  
  .filter-section__toggle {
    transition: transform 0.3s ease;
  }
  
  .filter-section.collapsed .filter-section__toggle {
    transform: rotate(-90deg);
  }
  
  .filter-section__content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.75rem;
    width: 100%;
    overflow: hidden;
  }
  
  .filter-section.collapsed .filter-section__content {
    display: none;
  }
  
  /* Metal Type Pills */
  .metal-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .metal-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 25px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: var(--bg-white, #fff);
    position: relative;
    user-select: none;
  }
  
  .metal-option:hover {
    border-color: var(--accent-gold, #dea882);
  }
  
  .metal-option.active {
    border-color: var(--accent-gold, #dea882);
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.1) 0%, rgba(201, 169, 98, 0.05) 100%);
  }
  
  .metal-option input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  
  .metal-swatch {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.1);
  }
  
  .metal-swatch--yellow-gold { background: linear-gradient(135deg, #FFD700 0%, #DAA520 100%); }
  .metal-swatch--white-gold { background: linear-gradient(135deg, #E8E8E8 0%, #C0C0C0 100%); }
  .metal-swatch--rose-gold { background: linear-gradient(135deg, #E8B4B8 0%, #B76E79 100%); }
  .metal-swatch--platinum { background: linear-gradient(135deg, #E5E4E2 0%, #B4B4B4 100%); }
  .metal-swatch--silver { background: linear-gradient(135deg, #C0C0C0 0%, #A8A8A8 100%); }
  
  .metal-option span {
    font-size: 0.8rem;
    color: #1a1a1a;
    font-weight: 500;
  }
  
  /* Carat Weight Slider */
  .carat-range {
    padding: 0.5rem 0;
  }
  
  .carat-buttons {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }
  
  .carat-btn {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 3px;
    background: var(--bg-white, #fff);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }
  
  .carat-btn:hover {
    border-color: var(--accent-gold, #dea882);
  }
  
  .carat-btn.active {
    border-color: var(--accent-gold, #dea882);
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.1) 0%, rgba(201, 169, 98, 0.05) 100%);
    color: var(--accent-gold-dark, #c89066);
    font-weight: 600;
  }
  
  /* Style Type Grid */
  .style-options {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  
  .style-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .style-option:hover {
    background: var(--bg-light, #efecec);
  }
  
  .style-option.active {
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.1) 0%, rgba(201, 169, 98, 0.05) 100%);
  }
  
  .style-option input {
    appearance: none;
    width: 18px;
    height: 18px;
    border: 1px solid var(--border-medium, #d1d5db);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
  }
  
  .style-option input:checked {
    background: var(--accent-gold, #dea882);
    border-color: var(--accent-gold, #dea882);
  }
  
  .style-option input:checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 4px;
    height: 8px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  
  .style-option span {
    font-size: 0.875rem;
    color: #1a1a1a;
    font-weight: 500;
  }
  
  /* Price Range */
  .price-inputs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    box-sizing: border-box;
  }
  
  .price-input {
    flex: 1;
    min-width: 0;
    max-width: calc(50% - 1rem);
    padding: 0.5rem 0.5rem;
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 3px;
    font-size: 0.8rem;
    text-align: center;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }
  
  .price-input:focus {
    outline: none;
    border-color: var(--accent-gold, #dea882);
  }
  
  .price-separator {
    color: var(--text-muted, #6b7280);
    font-weight: 500;
    flex-shrink: 0;
  }
  
  /* Apply Button */
  .filter-apply-btn {
    width: 100%;
    padding: 1rem;
    background: var(--primary-navy, #1c1a1a);
    color: white;
    border: none;
    border-radius: 3px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 1rem;
  }
  
  .filter-apply-btn:hover {
    background: var(--primary-navy-light, #2a2828);
    transform: translateY(-2px);
  }
  
  .filter-clear-btn {
    width: 100%;
    padding: 0.75rem;
    background: transparent;
    color: var(--text-muted, #6b7280);
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 3px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 0.5rem;
  }
  
  .filter-clear-btn:hover {
    border-color: var(--text-muted, #6b7280);
    color: var(--text-dark, #1c1a1a);
  }
  
  /* Active filters badge */
  .active-filters-count {
    background: var(--accent-gold, #dea882);
    color: var(--primary-navy, #1c1a1a);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    margin-left: auto;
  }
  
  /* Mobile filter toggle */
  .mobile-filter-toggle {
    display: none;
    width: 100%;
    padding: 1rem;
    background: var(--bg-white, #fff);
    border: 1px solid var(--border-light, #e5e7eb);
    border-radius: 3px;
    margin-bottom: 1rem;
    font-weight: 500;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  
  @media (max-width: 992px) {
    .collection-section {
      padding-top: 80px;
    }
    
    .collection-header h1 {
      font-size: 1.75rem !important;
    }
    
    .mobile-filter-toggle {
      display: flex;
      font-size: 0.9rem;
      padding: 0.875rem;
    }
    
    .sidebar-filters {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--bg-white, #fff);
      z-index: 1100;
      overflow-y: auto;
      padding: 1rem;
    }
    
    .sidebar-filters.open {
      display: block;
    }
    
    .mobile-filter-close {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 0;
      margin-bottom: 1rem;
      border-bottom: 1px solid var(--border-light, #e5e7eb);
    }
    
    .mobile-filter-close h3 {
      margin: 0;
      font-size: 1.25rem;
    }
    
    .mobile-filter-close button {
      background: none;
      border: none;
      font-size: 2rem;
      cursor: pointer;
      padding: 0.5rem;
      line-height: 1;
    }
    
    .listing-layout {
      display: block;
    }
    
    .products-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 12px !important;
    }
    
    .results-header {
      flex-direction: column;
      gap: 12px;
      align-items: stretch !important;
    }
    
    .results-count {
      text-align: center;
    }
    
    .sort-dropdown {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    
    .sort-dropdown select {
      width: 100%;
      padding: 10px;
      font-size: 0.9rem;
    }
  }
  
  @media (max-width: 480px) {
    .collection-section {
      padding-top: 70px;
    }
    
    .collection-header {
      margin-bottom: 1rem !important;
    }
    
    .collection-header h1 {
      font-size: 1.5rem !important;
      margin-bottom: 0.25rem !important;
    }
    
    .collection-header p {
      font-size: 0.85rem !important;
    }
    
    .products-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 8px !important;
    }
    
    .mobile-filter-toggle {
      padding: 0.75rem;
      font-size: 0.85rem;
      margin-bottom: 0.75rem;
    }
    
    /* Compact filter options on mobile */
    .metal-options {
      gap: 0.375rem;
    }
    
    .metal-option {
      padding: 0.4rem 0.75rem;
      font-size: 0.75rem;
    }
    
    .metal-swatch {
      width: 14px;
      height: 14px;
    }
    
    .carat-buttons {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.375rem;
    }
    
    .carat-btn {
      padding: 0.5rem;
      font-size: 0.75rem;
    }
    
    .style-option {
      padding: 0.5rem;
    }
    
    .style-option span {
      font-size: 0.8rem;
    }
    
    .filter-apply-btn {
      padding: 0.875rem;
      font-size: 0.85rem;
    }
  }
</style>
