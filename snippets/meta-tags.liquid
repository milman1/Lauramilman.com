{%- comment -%}
  Open Graph + Twitter Card meta tags.
  Provides og:image for every page type with a global fallback.
{%- endcomment -%}

{%- liquid
  assign og_title = page_title
  assign og_type  = 'website'
  assign og_image = nil

  if request.page_type == 'product'
    assign og_type  = 'product'
    assign og_title = product.title
    if product.featured_image
      assign og_image = product.featured_image | image_url: width: 1200
    endif

  elsif request.page_type == 'collection'
    assign og_type = 'product.group'
    assign og_title = collection.title
    if collection.image
      assign og_image = collection.image | image_url: width: 1200
    endif

  elsif request.page_type == 'article'
    assign og_type  = 'article'
    assign og_title = article.title
    if article.image
      assign og_image = article.image | image_url: width: 1200
    endif

  elsif request.page_type == 'page'
    assign og_title = page.title
    if page.image
      assign og_image = page.image | image_url: width: 1200
    endif
  endif

  unless og_image
    if settings.share_image
      assign og_image = settings.share_image | image_url: width: 1200, height: 628
    endif
  endunless
-%}

<meta property="og:type" content="{{ og_type }}">
<meta property="og:title" content="{{ og_title }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:description" content="{{ page_description | escape }}">

{%- if og_image -%}
  <meta property="og:image" content="https:{{ og_image }}">
  <meta property="og:image:secure_url" content="https:{{ og_image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="628">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | remove: ',' }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title }}">
<meta name="twitter:description" content="{{ page_description | escape }}">
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image }}">
{%- endif -%}
