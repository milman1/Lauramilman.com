{%- comment -%}
  Diamond Shape SVG Icons
{%- endcomment -%}

{%- case shape -%}
  {%- when 'round' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="1.5"/>
      <path d="M20 4 L28 20 L20 36 L12 20 Z" stroke="currentColor" stroke-width="1" fill="none"/>
      <circle cx="20" cy="20" r="6" stroke="currentColor" stroke-width="1"/>
    </svg>
  
  {%- when 'princess' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="6" y="6" width="28" height="28" stroke="currentColor" stroke-width="1.5"/>
      <path d="M6 6 L20 20 L34 6" stroke="currentColor" stroke-width="1"/>
      <path d="M6 34 L20 20 L34 34" stroke="currentColor" stroke-width="1"/>
    </svg>
  
  {%- when 'cushion' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="6" y="6" width="28" height="28" rx="6" stroke="currentColor" stroke-width="1.5"/>
      <path d="M20 6 L28 20 L20 34 L12 20 Z" stroke="currentColor" stroke-width="1" fill="none"/>
    </svg>
  
  {%- when 'emerald' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 6 L30 6 L34 12 L34 28 L30 34 L10 34 L6 28 L6 12 Z" stroke="currentColor" stroke-width="1.5"/>
      <rect x="12" y="12" width="16" height="16" stroke="currentColor" stroke-width="1"/>
    </svg>
  
  {%- when 'oval' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="20" cy="20" rx="12" ry="16" stroke="currentColor" stroke-width="1.5"/>
      <path d="M20 4 L26 20 L20 36 L14 20 Z" stroke="currentColor" stroke-width="1" fill="none"/>
    </svg>
  
  {%- when 'radiant' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 4 L30 4 L36 10 L36 30 L30 36 L10 36 L4 30 L4 10 Z" stroke="currentColor" stroke-width="1.5"/>
      <path d="M20 4 L28 20 L20 36 L12 20 Z" stroke="currentColor" stroke-width="1" fill="none"/>
    </svg>
  
  {%- when 'asscher' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="6" y="6" width="28" height="28" stroke="currentColor" stroke-width="1.5"/>
      <rect x="10" y="10" width="20" height="20" stroke="currentColor" stroke-width="1"/>
      <rect x="14" y="14" width="12" height="12" stroke="currentColor" stroke-width="1"/>
    </svg>
  
  {%- when 'marquise' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 2 C32 10 32 30 20 38 C8 30 8 10 20 2 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <path d="M20 2 L26 20 L20 38 L14 20 Z" stroke="currentColor" stroke-width="1" fill="none"/>
    </svg>
  
  {%- when 'heart' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 36 L6 22 C2 18 2 12 6 8 C10 4 16 4 20 10 C24 4 30 4 34 8 C38 12 38 18 34 22 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
    </svg>
  
  {%- when 'pear' -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 4 C30 12 32 24 26 32 C22 38 18 38 14 32 C8 24 10 12 20 4 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <path d="M20 4 L26 20 L20 36 L14 20 Z" stroke="currentColor" stroke-width="1" fill="none"/>
    </svg>
  
  {%- else -%}
    <svg class="shape-btn__icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="1.5"/>
    </svg>
{%- endcase -%}
