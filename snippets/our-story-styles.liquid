{%- comment -%} Laura Milman — Our Story (Milman Heritage) styles, extracted. {%- endcomment -%}
<style>
/* =============================================
   FLOATING DIAMONDS BACKGROUND
============================================= */
.floating-diamonds { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
.floating-diamond { position: absolute; opacity: 0.03; animation: float-drift 20s ease-in-out infinite; }
.floating-diamond:nth-child(1) { left: 10%; top: 20%; animation-delay: 0s; animation-duration: 25s; }
.floating-diamond:nth-child(2) { left: 80%; top: 10%; animation-delay: -5s; animation-duration: 30s; }
.floating-diamond:nth-child(3) { left: 20%; top: 60%; animation-delay: -10s; animation-duration: 22s; }
.floating-diamond:nth-child(4) { left: 70%; top: 70%; animation-delay: -15s; animation-duration: 28s; }
.floating-diamond:nth-child(5) { left: 50%; top: 40%; animation-delay: -8s; animation-duration: 35s; }
@keyframes float-drift {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-30px) rotate(5deg); }
  50% { transform: translateY(-10px) rotate(-3deg); }
  75% { transform: translateY(-40px) rotate(8deg); }
}

/* Story Page */
.story-page { background: #1c1a1a; color: #ffffff; position: relative; z-index: 1; }

/* HERO */
.story-hero { position: relative; min-height: 100vh; min-height: 100dvh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.story-hero__bg { position: absolute; inset: 0; background: url('{{ "hero-loose-diamonds.png" | asset_url }}') center center / cover no-repeat; }
.story-hero__bg::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(28, 26, 26, 0.55) 0%, rgba(28, 26, 26, 0.4) 40%, rgba(28, 26, 26, 0.7) 100%), radial-gradient(ellipse at 50% 50%, rgba(222, 168, 130, 0.08) 0%, transparent 60%); }
.story-hero__diamond { position: absolute; width: 600px; height: 600px; opacity: 0.04; animation: hero-diamond-pulse 6s ease-in-out infinite; }
@keyframes hero-diamond-pulse { 0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.04; } 50% { transform: scale(1.05) rotate(3deg); opacity: 0.06; } }
@keyframes shimmer { 0%, 100% { opacity: 1; } 50% { opacity: 0.7; } }
.story-hero__content { position: relative; text-align: center; padding: 2rem; max-width: 900px; }
.story-hero__eyebrow { font-size: 0.72rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--accent-gold); margin-bottom: 2rem; opacity: 0; animation: fadeUp 1s ease forwards 0.3s; font-weight: 600; }
.story-hero__title { font-family: var(--font-heading); font-size: clamp(3rem, 8vw, 6rem); font-weight: 400; line-height: 1.1; margin-bottom: 1.5rem; background: linear-gradient(135deg, #ffffff 0%, #dea882 50%, #ffffff 100%); background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: fadeUp 1s ease forwards 0.5s, gradientShift 8s linear infinite; opacity: 0; font-style: italic; }
@keyframes gradientShift { 0% { background-position: 0% center; } 100% { background-position: 200% center; } }
@keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
.story-hero__subtitle { font-size: 1.15rem; color: rgba(255, 255, 255, 0.78); font-weight: 300; opacity: 0; animation: fadeUp 1s ease forwards 0.7s; max-width: 620px; margin-left: auto; margin-right: auto; line-height: 1.7; }
.story-hero__line-left, .story-hero__line-right { position: absolute; width: 1px; height: 150px; background: linear-gradient(to bottom, transparent, var(--accent-gold), transparent); opacity: 0.3; }
.story-hero__line-left { left: 15%; top: 20%; }
.story-hero__line-right { right: 15%; bottom: 20%; }

.hero-trust-badges { position: absolute; bottom: 2.5rem; left: 0; right: 0; display: flex; align-items: center; justify-content: center; gap: 20px; opacity: 0; animation: fadeUp 1s ease forwards 1.2s; }
.hero-trust-badge { display: flex; align-items: center; gap: 7px; }
.hero-trust-badge svg { width: 20px; height: 20px; color: #dea882; flex-shrink: 0; }
.hero-trust-badge span { font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em; color: rgba(255, 255, 255, 0.78); white-space: nowrap; }
.hero-trust-badge__sep { color: rgba(255, 255, 255, 0.3); font-size: 0.85rem; font-weight: 300; line-height: 1; }
@media (max-width: 768px) { .hero-trust-badges { flex-wrap: wrap; gap: 8px 14px; bottom: 1.5rem; padding: 0 1rem; } .hero-trust-badge svg { width: 16px; height: 16px; } .hero-trust-badge span { font-size: 0.66rem; } .hero-trust-badge__sep { font-size: 0.6rem; } }

.section-divider { display: none; }

.story-section { padding: 4.5rem 2rem; position: relative; }
.story-section--dark { background: #1c1a1a; }
.story-section--mid { background: #322f2f; }
.story-section--light { background: #efecec; color: #322f2f; }
.story-section--centered { text-align: center; }
.story-container { max-width: 1200px; margin: 0 auto; }
.story-container--narrow { max-width: 800px; }

.story-label { font-size: 0.7rem; letter-spacing: 0.32em; text-transform: uppercase; color: var(--accent-gold); margin-bottom: 0.75rem; display: block; font-weight: 600; }
.story-label--center { text-align: center; }

.story-heading { font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.2; margin-bottom: 1.25rem; color: #ffffff; font-style: italic; }
.story-heading--large { font-size: clamp(2.5rem, 5vw, 4rem); }
.story-heading--center { text-align: center; }
.story-section--light .story-heading { color: #1c1a1a; }

.story-text { font-size: 1.1rem; line-height: 1.9; color: rgba(255, 255, 255, 0.78); }
.story-text p { margin-bottom: 1.5rem; }
.story-text p:last-child { margin-bottom: 0; }
.story-text--centered { text-align: center; }
.story-section--light .story-text { color: rgba(28, 26, 26, 0.75); }

.btn--outline.btn--dark { display: inline-block; padding: 1rem 2.5rem; font-size: 0.78rem; letter-spacing: 0.22em; text-transform: uppercase; text-decoration: none; border: 1px solid #1c1a1a; color: #1c1a1a; background: transparent; border-radius: 2px; transition: all 0.3s ease; }
.btn--outline.btn--dark:hover { background: #1c1a1a; color: #ffffff; }

/* Mission */
.story-mission { text-align: center; padding: 1.5rem 0; position: relative; }
.story-mission__diamonds { position: absolute; inset: 0; pointer-events: none; }
.story-mission__diamond-left, .story-mission__diamond-right { position: absolute; opacity: 0.1; }
.story-mission__diamond-left { left: 5%; top: 50%; transform: translateY(-50%); }
.story-mission__diamond-right { right: 5%; top: 50%; transform: translateY(-50%) scaleX(-1); }
.story-mission__label { font-size: 0.7rem; letter-spacing: 0.32em; text-transform: uppercase; color: var(--accent-gold); margin-bottom: 1.5rem; font-weight: 600; }
.story-mission__text { font-family: var(--font-heading); font-size: clamp(1.4rem, 3.2vw, 2.2rem); font-weight: 400; line-height: 1.55; font-style: italic; color: rgba(255, 255, 255, 0.92); margin-bottom: 1rem; }
.story-mission__author { font-size: 0.78rem; letter-spacing: 0.22em; color: var(--accent-gold); }

/* Split Sections */
.story-split { display: grid; grid-template-columns: 1fr 1fr; gap: 3.5rem; align-items: center; max-width: 1200px; margin: 0 auto; }
.story-section--reverse .story-split { direction: rtl; }
.story-section--reverse .story-split > * { direction: ltr; }

/* Diamond Visual Cards */
.story-visual { position: relative; aspect-ratio: 4/5; background: linear-gradient(135deg, rgba(222, 168, 130, 0.05) 0%, rgba(28, 26, 26, 0.8) 100%); border-radius: 4px; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 1px solid rgba(222, 168, 130, 0.1); }
.story-visual__glow { position: absolute; width: 300px; height: 300px; background: radial-gradient(circle, rgba(222, 168, 130, 0.15) 0%, transparent 70%); animation: glow-pulse 4s ease-in-out infinite; }
@keyframes glow-pulse { 0%, 100% { transform: scale(1); opacity: 0.5; } 50% { transform: scale(1.2); opacity: 0.8; } }
.story-visual__diamond { position: relative; width: 180px; height: 220px; }
.story-visual__diamond svg { width: 100%; height: 100%; filter: drop-shadow(0 0 40px rgba(222, 168, 130, 0.3)); }
.story-visual__diamond--animated svg { animation: diamond-float 5s ease-in-out infinite; }
@keyframes diamond-float { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-15px) rotate(2deg); } }
.story-visual__sparkles { position: absolute; inset: 0; pointer-events: none; }
.sparkle { position: absolute; width: 6px; height: 6px; background: radial-gradient(circle, var(--accent-gold) 0%, transparent 70%); border-radius: 50%; animation: sparkle 3s ease-in-out infinite; }
.sparkle:nth-child(1) { left: 20%; top: 25%; animation-delay: 0s; }
.sparkle:nth-child(2) { left: 75%; top: 35%; animation-delay: 0.5s; }
.sparkle:nth-child(3) { left: 30%; top: 70%; animation-delay: 1s; }
.sparkle:nth-child(4) { left: 65%; top: 60%; animation-delay: 1.5s; }
.sparkle:nth-child(5) { left: 50%; top: 15%; animation-delay: 0.8s; }
@keyframes sparkle { 0%, 100% { opacity: 0; transform: scale(0.5); } 50% { opacity: 1; transform: scale(1.2); } }

/* Process */
.story-process { display: flex; justify-content: center; align-items: center; gap: 2rem; padding: 1rem 0; }
.story-process__step { display: flex; flex-direction: column; align-items: center; text-align: center; }
.story-process__icon { width: 100px; height: 100px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(222, 168, 130, 0.1) 0%, transparent 100%); border-radius: 50%; margin-bottom: 1rem; border: 1px solid rgba(222, 168, 130, 0.2); }
.story-process__icon svg { width: 50px; height: 50px; color: var(--accent-gold); }
.story-process__label { font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255, 255, 255, 0.6); }
.story-process__caption { font-size: 0.65rem; letter-spacing: 0.1em; color: rgba(255, 255, 255, 0.4); margin-top: 0.25rem; font-style: italic; }
.story-process__arrow { color: var(--accent-gold); opacity: 0.4; }

/* Pillars */
.story-section--pillars { padding: 4.5rem 2rem; }
.story-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; margin-top: 2rem; }
.story-pillar { position: relative; padding: 2rem; background: linear-gradient(180deg, rgba(222, 168, 130, 0.05) 0%, transparent 100%); border-radius: 4px; border-top: 1px solid var(--accent-gold); }
.story-pillar__icon { width: 60px; height: 60px; margin-bottom: 1.5rem; color: var(--accent-gold); }
.story-pillar__number { font-size: 0.78rem; color: var(--accent-gold); letter-spacing: 0.18em; margin-bottom: 1rem; }
.story-pillar__title { font-family: var(--font-heading); font-size: 1.4rem; font-weight: 400; margin-bottom: 1rem; color: #ffffff; font-style: italic; }
.story-pillar__text { font-size: 1rem; line-height: 1.8; color: rgba(255, 255, 255, 0.7); }

/* Stats */
.story-section--stats { background: linear-gradient(135deg, #322f2f 0%, #1c1a1a 100%); padding: 3.5rem 2rem; }
.story-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 3rem; text-align: center; }
.story-stat { padding: 1.25rem; }
.story-stat__icon { width: 40px; height: 40px; margin: 0 auto 1rem; color: var(--accent-gold); opacity: 0.6; }
.story-stat__number { display: block; font-family: var(--font-heading); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 400; color: var(--accent-gold); margin-bottom: 0.5rem; font-style: italic; }
.story-stat__label { font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255, 255, 255, 0.6); }

/* CTA */
.story-section--cta { background: linear-gradient(135deg, var(--accent-gold) 0%, #c89066 100%); color: #1c1a1a; text-align: center; padding: 4.5rem 2rem; position: relative; overflow: hidden; }
.story-section--cta::before { content: ''; position: absolute; width: 500px; height: 500px; background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%); top: -250px; right: -100px; }
.story-cta__title { font-family: var(--font-heading); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 400; margin-bottom: 1rem; font-style: italic; }
.story-cta__text { font-size: 1.1rem; color: rgba(28, 26, 26, 0.78); margin-bottom: 1.5rem; max-width: 620px; margin-left: auto; margin-right: auto; line-height: 1.7; }
.story-cta__buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.story-cta__buttons .btn--primary { background: #1c1a1a; color: #ffffff; }
.story-cta__buttons .btn--secondary { border-color: #1c1a1a; color: #1c1a1a; }

/* Responsive */
@media (max-width: 992px) {
  .story-split { grid-template-columns: 1fr; gap: 3rem; }
  .story-section--reverse .story-split { direction: ltr; }
  .story-pillars { grid-template-columns: 1fr; gap: 2rem; }
  .story-stats { grid-template-columns: repeat(2, 1fr); }
  .story-process { flex-wrap: wrap; }
  .floating-diamonds { display: none; }
}
@media (max-width: 768px) {
  .story-section { padding: 3rem 1.25rem; }
  .story-hero__diamond { width: 300px; height: 300px; }
  .story-split { gap: 1.5rem; }
  .story-pillars { gap: 1.5rem; margin-top: 1.5rem; }
  .story-stats { gap: 1rem; }
  .story-stat { padding: 0.75rem; }
  .story-heading { margin-bottom: 1rem; }
  .story-section--stats { padding: 2.5rem 1.25rem; }
  .story-section--cta { padding: 3rem 1.25rem; }
  .story-visual { aspect-ratio: 1 / 1; max-width: 200px; margin: 0 auto; }
  .story-visual__glow { width: 150px; height: 150px; }
  .story-visual__diamond { width: 100px; height: 120px; }
}

/* FEATURED PRODUCTS — EDITORIAL */
.fp { padding: 3rem 2rem 2.5rem; background: #ffffff; position: relative; overflow: hidden; }
.fp__header { text-align: center; max-width: 640px; margin: 0 auto 2rem; }
.fp__eyebrow { display: block; font-size: 0.7rem; letter-spacing: 0.32em; text-transform: uppercase; color: #dea882; margin-bottom: 0.75rem; font-weight: 600; }
.fp__title { font-family: var(--font-heading); font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 400; color: #1c1a1a; margin: 0 0 1rem; line-height: 1.2; font-style: italic; }
.fp__title-line { width: 50px; height: 1px; background: #dea882; margin: 0 auto 1rem; }
.fp__subtitle { font-size: 0.95rem; color: #666; margin: 0; line-height: 1.7; }

.fp__bento { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; max-width: 1100px; margin: 0 auto 2rem; }
.fp__card { display: flex; flex-direction: column; text-decoration: none; color: inherit; border-radius: 4px; overflow: hidden; background: #1c1a1a; transition: transform 0.3s ease, box-shadow 0.3s ease; }
.fp__card:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3); }
.fp__card-media { position: relative; aspect-ratio: 1 / 1; overflow: hidden; background: #000; }
.fp__card-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.fp__card:hover .fp__card-media img { transform: scale(1.05); }
.fp__card-video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.5s ease; z-index: 1; }
.fp__card-yt-wrap { position: absolute; top: -60px; bottom: -60px; left: -60px; right: -60px; z-index: 1; opacity: 0; transition: opacity 0.5s ease; pointer-events: none; }
.fp__card-yt-wrap iframe { width: 100%; height: 100%; border: 0; }
.fp__card:hover .fp__card-video--playing, .fp__card:hover .fp__card-yt-wrap--playing { opacity: 1; }
.fp__cycle-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.5s ease; }
.fp__cycle-img.fp__cycle-img--active { opacity: 1; }
.fp__card-info { padding: 1rem 1.25rem 1.25rem; flex: 1; display: flex; flex-direction: column; }
.fp__card-name { font-family: var(--font-heading); font-size: 0.95rem; font-weight: 400; color: #fff; margin: 0 0 0.3rem; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.fp__card-price { font-size: 0.9rem; font-weight: 500; color: #dea882; margin: 0; }
.fp__hero-card, .fp__side-card, .fp__side-stack { display: none; }

.fp__runway-wrap { max-width: 1280px; margin: 0 auto; }
.fp__runway-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
.fp__runway-label { font-family: var(--font-heading); font-size: 1.15rem; font-weight: 400; color: #1c1a1a; margin: 0; font-style: italic; }
.fp__runway-arrows { display: flex; gap: 8px; }
.fp__arrow { width: 40px; height: 40px; border-radius: 50%; border: 1px solid #ddd; background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #1c1a1a; transition: all 0.25s ease; }
.fp__arrow:hover { border-color: #1c1a1a; background: #1c1a1a; color: #fff; }
.fp__runway { display: flex; gap: 20px; overflow-x: auto; scroll-behavior: smooth; scrollbar-width: none; -ms-overflow-style: none; padding-bottom: 8px; scroll-snap-type: x mandatory; }
.fp__runway::-webkit-scrollbar { display: none; }
.fp__runway-card { flex: 0 0 260px; scroll-snap-align: start; }

.fp__footer { text-align: center; margin-top: 1.5rem; }
.fp__view-all { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 600; color: #1c1a1a; text-decoration: none; border: 1px solid #1c1a1a; padding: 12px 32px; border-radius: 2px; transition: all 0.3s ease; }
.fp__view-all:hover { background: #1c1a1a; color: #ffffff; }
.fp__view-all svg { transition: transform 0.3s ease; }
.fp__view-all:hover svg { transform: translateX(4px); }

@media (max-width: 1024px) { .fp__bento { grid-template-columns: repeat(3, 1fr); } .fp__runway-card { flex: 0 0 230px; } }
@media (max-width: 768px) { .fp { padding: 2rem 1rem 2rem; } .fp__header { margin-bottom: 1.5rem; } .fp__bento { grid-template-columns: 1fr; gap: 1rem; } .fp__subtitle { font-size: 0.85rem; } .fp__runway-card { flex: 0 0 200px; } .fp__view-all { font-size: 0.7rem; padding: 10px 24px; } }
@media (hover: none) and (pointer: coarse) { .fp__card:hover .fp__card-media img { transform: none; } .fp__card:hover { box-shadow: none; transform: none; } }

/* SHOP THE LOOK */
.stl { padding: 4rem 2rem; background: #16161f; }
.stl__header { text-align: center; max-width: 600px; margin: 0 auto 2.5rem; }
.stl__eyebrow { display: block; font-size: 0.7rem; letter-spacing: 0.32em; text-transform: uppercase; color: #dea882; margin-bottom: 0.5rem; font-weight: 600; }
.stl__heading { font-family: var(--font-heading); font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 400; color: #fff; margin: 0 0 0.6rem; line-height: 1.15; font-style: italic; }
.stl__line { width: 50px; height: 1px; background: #dea882; margin: 0 auto; }
.stl__grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 1.5rem; max-width: 1200px; margin: 0 auto; align-items: stretch; }
.stl__lifestyle { position: relative; border-radius: 4px; overflow: hidden; min-height: 520px; }
.stl__lifestyle img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s ease; }
.stl__lifestyle:hover img { transform: scale(1.03); }
.stl__lifestyle-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem 1.5rem 1.5rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%); }
.stl__lifestyle-label { font-family: var(--font-heading); font-size: 1.3rem; color: #fff; font-weight: 400; letter-spacing: 0.02em; font-style: italic; }
.stl__lifestyle-sub { font-size: 0.78rem; color: rgba(255,255,255,0.65); margin-top: 0.25rem; letter-spacing: 0.05em; }
.stl__products { display: flex; flex-direction: column; gap: 1rem; }
.stl__product { display: flex; align-items: center; gap: 1.25rem; background: #1c1a1a; border: 1px solid rgba(255,255,255,0.06); border-radius: 4px; padding: 0.85rem; text-decoration: none; color: #fff; transition: background 0.3s ease, border-color 0.3s ease, transform 0.25s ease; flex: 1; min-height: 0; }
.stl__product:hover { background: #322f2f; border-color: rgba(222,168,130,0.25); transform: translateX(4px); }
.stl__product-img-wrap { flex: 0 0 110px; width: 110px; height: 110px; border-radius: 4px; overflow: hidden; background: #fff; }
.stl__product-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
.stl__product:hover .stl__product-img-wrap img { transform: scale(1.08); }
.stl__product-details { flex: 1; min-width: 0; }
.stl__product-name { font-family: var(--font-heading); font-size: 0.95rem; font-weight: 400; color: #fff; margin: 0 0 0.3rem; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.stl__product-price { font-size: 0.85rem; color: #dea882; margin: 0 0 0.6rem; font-weight: 500; }
.stl__product-cta { display: inline-block; font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.5); border-bottom: 1px solid rgba(255,255,255,0.15); padding-bottom: 2px; transition: color 0.3s ease, border-color 0.3s ease; }
.stl__product:hover .stl__product-cta { color: #dea882; border-color: #dea882; }
.stl__footer { text-align: center; margin-top: 2rem; }
.stl__view-all { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.6); text-decoration: none; padding: 10px 28px; border: 1px solid rgba(255,255,255,0.15); border-radius: 30px; transition: all 0.3s ease; }
.stl__view-all:hover { background: rgba(222,168,130,0.1); border-color: rgba(222,168,130,0.4); color: #dea882; }
